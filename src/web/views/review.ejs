<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sentinel-Graph — Diff Review</title>
  <meta name="description" content="Side-by-side code diff visualization from AI-powered code review">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
        },
      },
    }
  </script>
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    .gradient-bg {
      background: linear-gradient(135deg, #0f0c29 0%, #1a1a2e 30%, #16213e 60%, #0f3460 100%);
    }
    .glass {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .glow-border {
      border: 1px solid transparent;
      background-image: linear-gradient(rgba(15, 15, 30, 0.9), rgba(15, 15, 30, 0.9)),
                         linear-gradient(135deg, #667eea, #764ba2, #f093fb);
      background-origin: border-box;
      background-clip: padding-box, border-box;
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
  </style>
</head>
<body class="gradient-bg min-h-screen text-white">

  <div id="root"></div>

  <script>
    window.__DIFF_DATA__ = {
      original_code: <%- JSON.stringify(original_code) %>,
      final_code: <%- JSON.stringify(final_code) %>,
      diff: <%- diff %>
    };
  </script>

  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <script type="text/babel">
    const { useState } = React;

    function DiffViewer() {
      const { original_code, final_code, diff } = window.__DIFF_DATA__;
      const [viewMode, setViewMode] = useState('split');

      const leftLines = [];
      const rightLines = [];
      let leftNum = 1;
      let rightNum = 1;

      diff.forEach((change) => {
        const lines = change.value.replace(/\n$/, '').split('\n');
        lines.forEach((line) => {
          if (change.removed) {
            leftLines.push({ num: leftNum++, text: line, type: 'removed' });
            rightLines.push({ num: null, text: '', type: 'empty' });
          } else if (change.added) {
            leftLines.push({ num: null, text: '', type: 'empty' });
            rightLines.push({ num: rightNum++, text: line, type: 'added' });
          } else {
            leftLines.push({ num: leftNum++, text: line, type: 'unchanged' });
            rightLines.push({ num: rightNum++, text: line, type: 'unchanged' });
          }
        });
      });

      const unifiedLines = [];
      let uLeftNum = 1;
      let uRightNum = 1;
      diff.forEach((change) => {
        const lines = change.value.replace(/\n$/, '').split('\n');
        lines.forEach((line) => {
          if (change.removed) {
            unifiedLines.push({ leftNum: uLeftNum++, rightNum: null, text: line, type: 'removed' });
          } else if (change.added) {
            unifiedLines.push({ leftNum: null, rightNum: uRightNum++, text: line, type: 'added' });
          } else {
            unifiedLines.push({ leftNum: uLeftNum++, rightNum: uRightNum++, text: line, type: 'unchanged' });
          }
        });
      });

      const lineStyles = {
        removed: 'bg-red-500/10 border-l-2 border-red-500',
        added: 'bg-emerald-500/10 border-l-2 border-emerald-500',
        unchanged: 'border-l-2 border-transparent',
        empty: 'bg-white/[0.02] border-l-2 border-transparent',
      };

      const numStyles = {
        removed: 'text-red-400/60',
        added: 'text-emerald-400/60',
        unchanged: 'text-gray-600',
        empty: 'text-transparent',
      };

      const textStyles = {
        removed: 'text-red-300',
        added: 'text-emerald-300',
        unchanged: 'text-gray-300',
        empty: '',
      };

      const prefixes = {
        removed: '−',
        added: '+',
        unchanged: ' ',
        empty: ' ',
      };

      const stats = diff.reduce((acc, change) => {
        const lines = change.value.replace(/\n$/, '').split('\n').length;
        if (change.added) acc.added += lines;
        else if (change.removed) acc.removed += lines;
        return acc;
      }, { added: 0, removed: 0 });

      function renderPane(lines, title) {
        return (
          <div className="flex-1 min-w-0">
            <div className="sticky top-0 z-10 flex items-center gap-2 px-4 py-2.5 bg-black/60 backdrop-blur-sm border-b border-white/5">
              <span className={`w-2 h-2 rounded-full ${title === 'Original' ? 'bg-red-400' : 'bg-emerald-400'}`}></span>
              <span className="text-xs font-semibold uppercase tracking-wider text-gray-400">{title}</span>
            </div>
            <div className="font-mono text-xs leading-6">
              {lines.map((line, i) => (
                <div key={i} className={`flex ${lineStyles[line.type]} hover:bg-white/[0.03] transition-colors`}>
                  <span className={`flex-shrink-0 w-12 text-right pr-3 select-none ${numStyles[line.type]}`}>
                    {line.num || ''}
                  </span>
                  <span className={`flex-shrink-0 w-5 text-center select-none ${line.type === 'removed' ? 'text-red-400' : line.type === 'added' ? 'text-emerald-400' : 'text-gray-600'}`}>
                    {prefixes[line.type]}
                  </span>
                  <span className={`flex-1 pr-4 whitespace-pre ${textStyles[line.type]}`}>
                    {line.text}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      }

      function renderUnified() {
        return (
          <div className="font-mono text-xs leading-6">
            <div className="sticky top-0 z-10 flex items-center gap-2 px-4 py-2.5 bg-black/60 backdrop-blur-sm border-b border-white/5">
              <span className="text-xs font-semibold uppercase tracking-wider text-gray-400">Unified Diff</span>
            </div>
            {unifiedLines.map((line, i) => (
              <div key={i} className={`flex ${lineStyles[line.type]} hover:bg-white/[0.03] transition-colors`}>
                <span className={`flex-shrink-0 w-12 text-right pr-2 select-none ${numStyles[line.type]}`}>
                  {line.leftNum || ''}
                </span>
                <span className={`flex-shrink-0 w-12 text-right pr-3 select-none ${numStyles[line.type]}`}>
                  {line.rightNum || ''}
                </span>
                <span className={`flex-shrink-0 w-5 text-center select-none ${line.type === 'removed' ? 'text-red-400' : line.type === 'added' ? 'text-emerald-400' : 'text-gray-600'}`}>
                  {prefixes[line.type]}
                </span>
                <span className={`flex-1 pr-4 whitespace-pre ${textStyles[line.type]}`}>
                  {line.text}
                </span>
              </div>
            ))}
          </div>
        );
      }

      return (
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          {/* Header */}
          <div className="text-center mb-8 fade-in-up">
            <div className="inline-flex items-center gap-3 mb-3">
              <div className="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/30">
                <svg className="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h1 className="text-3xl font-black tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-indigo-300 via-purple-300 to-pink-300">
                Sentinel-Graph
              </h1>
            </div>
            <p className="text-gray-400 text-sm">Refactoring Complete</p>
          </div>

          {/* Stats & Controls */}
          <div className="flex items-center justify-between mb-6 fade-in-up">
            <div className="flex items-center gap-4">
              <div className="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gradient-to-r from-green-500 to-emerald-500 text-xs font-semibold uppercase tracking-wider">
                <span className="w-2 h-2 rounded-full bg-green-200"></span>
                Completed
              </div>
              <p className="text-sm text-gray-400">
                <span className="text-emerald-400 font-semibold">+{stats.added}</span>
                {' / '}
                <span className="text-red-400 font-semibold">−{stats.removed}</span>
                {' lines'}
              </p>
            </div>
            <div className="flex items-center gap-2">
              <div className="glass rounded-lg p-0.5 flex">
                <button
                  onClick={() => setViewMode('split')}
                  className={`px-3 py-1.5 rounded-md text-xs font-medium transition-all ${viewMode === 'split' ? 'bg-indigo-600 text-white' : 'text-gray-400 hover:text-white'}`}
                >
                  Split
                </button>
                <button
                  onClick={() => setViewMode('unified')}
                  className={`px-3 py-1.5 rounded-md text-xs font-medium transition-all ${viewMode === 'unified' ? 'bg-indigo-600 text-white' : 'text-gray-400 hover:text-white'}`}
                >
                  Unified
                </button>
              </div>
              <a
                href="/"
                className="inline-flex items-center gap-2 px-4 py-2 rounded-xl glass hover:bg-white/5 text-sm font-medium text-gray-300 transition-all"
              >
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                New Review
              </a>
            </div>
          </div>

          {/* Diff Container */}
          <div className="glow-border rounded-2xl overflow-hidden fade-in-up" style={{animationDelay: '0.1s'}}>
            {viewMode === 'split' ? (
              <div className="flex divide-x divide-white/5 overflow-x-auto">
                {renderPane(leftLines, 'Original')}
                {renderPane(rightLines, 'Refactored')}
              </div>
            ) : (
              renderUnified()
            )}
          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<DiffViewer />);
  </script>
</body>
</html>
