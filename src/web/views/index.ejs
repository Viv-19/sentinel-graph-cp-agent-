    /* ═══════════════════════════════════════════════
       STATUS BADGE
       ═══════════════════════════════════════════════ */

    function StatusBadge({ status }) {
      const map = {
        idle:      { label: 'Ready',       bg: 'rgba(74,222,128,0.08)', color: '#8b949e', dot: '#3b5249' },
        loading:   { label: 'Analyzing',   bg: 'rgba(74,222,128,0.15)', color: '#86efac', dot: '#4ade80' },
        pending:   { label: 'Pending',     bg: 'rgba(251,191,36,0.15)', color: '#fbbf24', dot: '#f59e0b' },
        approving: { label: 'Committing',  bg: 'rgba(16,185,129,0.15)', color: '#6ee7b7', dot: '#34d399' },
        completed: { label: 'Completed',   bg: 'rgba(74,222,128,0.15)', color: '#4ade80', dot: '#4ade80' },
        error:     { label: 'Error',       bg: 'rgba(248,81,73,0.15)',  color: '#f85149', dot: '#f85149' },
      };
      const cfg = map[status] || map.idle;
      return (
        <div className="status-pill" style={{ background: cfg.bg, color: cfg.color }}>
          <span style={{ width: 6, height: 6, borderRadius: '50%', background: cfg.dot, display: 'inline-block' }}
                className={status === 'loading' || status === 'approving' ? 'pulse-dot' : ''} />
          {cfg.label}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       EDITOR COMPONENT (Monaco Wrapper)
       ═══════════════════════════════════════════════ */

    function Editor({ value, onChange, disabled, theme }) {
      const containerRef = useRef(null);
      const editorRef = useRef(null);
      const isSettingValue = useRef(false);

      useEffect(() => {
        let disposed = false;

        require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' } });

        require(['vs/editor/editor.main'], function (monaco) {
          if (disposed || !containerRef.current) return;

          monaco.editor.defineTheme('sentinel-dark', {
            base: 'vs-dark',
            inherit: true,
            rules: [
              { token: 'comment', foreground: '6a737d', fontStyle: 'italic' },
              { token: 'keyword', foreground: '86efac' },
              { token: 'string', foreground: 'a7f3d0' },
              { token: 'number', foreground: '4ade80' },
              { token: 'type', foreground: 'fbbf24' },
            ],
            colors: {
              'editor.background': '#0a1210',
              'editor.foreground': '#e6edf3',
              'editor.lineHighlightBackground': '#111d1980',
              'editor.selectionBackground': '#16513540',
              'editorLineNumber.foreground': '#3b5249',
              'editorLineNumber.activeForeground': '#8b949e',
              'editorCursor.foreground': '#4ade80',
              'editor.inactiveSelectionBackground': '#16513520',
              'editorIndentGuide.background': '#1a2e26',
              'editorIndentGuide.activeBackground': '#2d4a3e',
            },
          });

          const editor = monaco.editor.create(containerRef.current, {
            value: value || '',
            language: 'javascript',
            theme: theme === 'vs-dark' ? 'sentinel-dark' : 'vs',
            fontFamily: "'JetBrains Mono', monospace",
            fontSize: 13,
            lineHeight: 20,
            padding: { top: 12, bottom: 12 },
            minimap: { enabled: false },
            scrollBeyondLastLine: false,
            automaticLayout: true,
            wordWrap: 'on',
            tabSize: 2,
            renderLineHighlight: 'line',
            cursorBlinking: 'smooth',
            cursorSmoothCaretAnimation: 'on',
            smoothScrolling: true,
            bracketPairColorization: { enabled: true },
            guides: { indentation: true, bracketPairs: true },
            overviewRulerBorder: false,
            hideCursorInOverviewRuler: true,
            scrollbar: {
              verticalScrollbarSize: 6,
              horizontalScrollbarSize: 6,
              verticalSliderSize: 6,
            },
            readOnly: !!disabled,
          });

          editorRef.current = editor;

          editor.onDidChangeModelContent(() => {
            if (!isSettingValue.current && onChange) {
              onChange(editor.getValue());
            }
          });

          const model = editor.getModel();
          if (model) {
            const detectedLang = detectLanguage(value || '');
            if (detectedLang) {
              monaco.editor.setModelLanguage(model, detectedLang);
            }
          }
        });

        return () => {
          disposed = true;
          if (editorRef.current) {
            editorRef.current.dispose();
            editorRef.current = null;
          }
        };
      }, []);

      useEffect(() => {
        if (editorRef.current && value !== undefined) {
          const current = editorRef.current.getValue();
          if (current !== value) {
            isSettingValue.current = true;
            editorRef.current.setValue(value);
            isSettingValue.current = false;
          }
        }
      }, [value]);

      useEffect(() => {
        if (editorRef.current) {
          editorRef.current.updateOptions({ readOnly: !!disabled });
        }
      }, [disabled]);

      function detectLanguage(code) {
        if (/^\s*(import|from|def |class |if __name__)/.test(code)) return 'python';
        if (/^\s*(package |func |import "|\tgo )/.test(code)) return 'go';
        if (/^\s*(use |fn |let mut |impl |struct )/.test(code)) return 'rust';
        if (/^\s*(import|export|interface |type |const |=>)/.test(code) && /:\s*(string|number|boolean)/.test(code)) return 'typescript';
        if (/^\s*(public class|private |System\.out|import java)/.test(code)) return 'java';
        if (/^\s*(#include|std::|int main|cout|cin)/.test(code)) return 'cpp';
        if (/<\/?[a-z][\s\S]*>/i.test(code) && /className|onClick|useState/.test(code)) return 'javascript';
        return 'javascript';
      }

      return <div ref={containerRef} id="monaco-container" />;
    }

    /* ═══════════════════════════════════════════════
       LOGS PANEL (Agent Activity Log)
       ═══════════════════════════════════════════════ */

    const AGENT_STEPS = [
      { id: 'router',    IconComp: SearchIcon,    label: 'Router',        detail: 'Analyzing code structure and routing to agents...' },
      { id: 'bughunter', IconComp: BugIcon,       label: 'BugHunter',     detail: 'Scanning for bugs, errors, and edge cases...' },
      { id: 'styleguard',IconComp: WandIcon,      label: 'StyleGuard',    detail: 'Checking code style, naming, and conventions...' },
      { id: 'perfarch',  IconComp: ZapIcon,       label: 'PerfArchitect', detail: 'Analyzing performance patterns and optimizations...' },
      { id: 'aggregate', IconComp: ClipboardIcon, label: 'Aggregator',    detail: 'Compiling findings and generating report...' },
    ];

    const PROBLEM_AGENT_STEPS = [
      { id: 'problem_analyzer',    IconComp: FileTextIcon,    label: 'ProblemAnalyzer',      detail: 'Parsing problem description and extracting structure...' },
      { id: 'constraint_analyzer', IconComp: RulerIcon,       label: 'ConstraintAnalyzer',   detail: 'Analyzing constraints and inferring limits...' },
      { id: 'complexity_estimator',IconComp: BarChartIcon,    label: 'ComplexityEstimator',  detail: 'Estimating required time and space complexity...' },
      { id: 'pattern_recognizer',  IconComp: PuzzleIcon,      label: 'PatternRecognizer',   detail: 'Detecting algorithm pattern from problem...' },
      { id: 'strategy_planner',    IconComp: MapIcon,         label: 'StrategyPlanner',      detail: 'Building an optimal strategy plan...' },
      { id: 'test_validator',      IconComp: CheckCircleIcon, label: 'TestCaseValidator',    detail: 'Simulating strategy over sample test cases...' },
    ];

    function LogsPanel({ loading, completed }) {
      const [visibleLogs, setVisibleLogs] = useState([]);
      const intervalRef = useRef(null);

      useEffect(() => {
        if (loading && !completed) {
          setVisibleLogs([]);
          let step = 0;
          intervalRef.current = setInterval(() => {
            if (step < AGENT_STEPS.length) {
              setVisibleLogs(prev => {
                const updated = prev.map(l => ({ ...l, status: 'done' }));
                updated.push({ ...AGENT_STEPS[step], status: 'running' });
                return updated;
              });
              step++;
            } else {
              clearInterval(intervalRef.current);
            }
          }, 2000);
        }

        if (completed) {
          clearInterval(intervalRef.current);
          setVisibleLogs(AGENT_STEPS.map(s => ({ ...s, status: 'done' })));
        }

        return () => clearInterval(intervalRef.current);
      }, [loading, completed]);

      if (!loading && !completed && visibleLogs.length === 0) {
        return (
          <div className="empty-state">
            <TerminalIcon size={40} />
            <p>Agent activity logs will appear here when you start a code review.</p>
          </div>
        );
      }

      return (
        <div>
          <div style={{ marginBottom: 12 }}>
            <span style={{ fontSize: 11, fontWeight: 600, color: '#8b949e', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
              Agent Pipeline
            </span>
          </div>
          {visibleLogs.map((log, idx) => (
            <div key={log.id} className={`log-entry ${log.status}`} style={{ animationDelay: `${idx * 50}ms` }}>
              <span style={{ lineHeight: 1, flexShrink: 0, marginTop: 2, color: '#4ade80' }}><log.IconComp size={16} /></span>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 2 }}>
                  <span style={{ fontSize: 13, fontWeight: 600, color: '#e6edf3' }}>{log.label}</span>
                  {log.status === 'running' && <SpinnerIcon size={12} />}
                  {log.status === 'done' && <span style={{ color: '#4ade80' }}><CheckIcon size={12} /></span>}
                </div>
                <p style={{ fontSize: 12, color: '#8b949e', margin: 0 }}>{log.detail}</p>
              </div>
              <span style={{ fontSize: 11, color: log.status === 'done' ? '#4ade80' : '#6e7681', flexShrink: 0, fontWeight: 500 }}>
                {log.status === 'done' ? 'Done' : 'Running'}
              </span>
            </div>
          ))}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       PROBLEM AGENT TRACKER
       ═══════════════════════════════════════════════ */

    function ProblemAgentTracker({ running, completed }) {
      const [visibleSteps, setVisibleSteps] = useState([]);
      const intervalRef = useRef(null);
      const timerRef = useRef(null);
      const [elapsed, setElapsed] = useState(0);

      useEffect(() => {
        if (running && !completed) {
          setVisibleSteps([]);
          setElapsed(0);
          let step = 0;

          // Progress through agents at ~15s intervals (realistic for LLM calls)
          intervalRef.current = setInterval(() => {
            if (step < PROBLEM_AGENT_STEPS.length) {
              setVisibleSteps(prev => {
                const updated = prev.map(s => ({ ...s, status: 'done' }));
                updated.push({ ...PROBLEM_AGENT_STEPS[step], status: 'running' });
                return updated;
              });
              step++;
            } else {
              // Keep last step as running until completed
              clearInterval(intervalRef.current);
            }
          }, 1500);

          // Show first step immediately
          setVisibleSteps([{ ...PROBLEM_AGENT_STEPS[0], status: 'running' }]);
          step = 1;

          // Timer
          timerRef.current = setInterval(() => {
            setElapsed(prev => prev + 1);
          }, 1000);
        }

        if (completed) {
          clearInterval(intervalRef.current);
          clearInterval(timerRef.current);
          setVisibleSteps(PROBLEM_AGENT_STEPS.map(s => ({ ...s, status: 'done' })));
        }

        return () => {
          clearInterval(intervalRef.current);
          clearInterval(timerRef.current);
        };
      }, [running, completed]);

      if (!running && !completed) return null;

      const formatTime = (s) => {
        const m = Math.floor(s / 60);
        const sec = s % 60;
        return m > 0 ? `${m}m ${sec}s` : `${sec}s`;
      };

      return (
        <div style={{
          background: 'rgba(74, 222, 128, 0.06)',
          border: '1px solid rgba(74, 222, 128, 0.2)',
          borderRadius: 10,
          padding: '14px 16px',
          marginBottom: 12,
        }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 10 }}>
            <span style={{ fontSize: 11, fontWeight: 700, color: '#4ade80', textTransform: 'uppercase', letterSpacing: '0.06em' }}>
              {completed ? 'Analysis Pipeline Complete' : 'Analysis Pipeline Running'}
            </span>
            <span style={{ fontSize: 11, color: '#8b949e', fontFamily: "'JetBrains Mono', monospace" }}>
              {formatTime(elapsed)}
            </span>
          </div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
            {visibleSteps.map((step, idx) => (
              <div key={step.id} style={{
                display: 'flex', alignItems: 'center', gap: 10,
                padding: '6px 10px', borderRadius: 8,
                background: step.status === 'running' ? 'rgba(74, 222, 128, 0.08)' : 'transparent',
                transition: 'all 0.3s ease',
                animation: step.status === 'running' ? 'fadeIn 0.3s ease' : undefined,
              }}>
                <span style={{ lineHeight: 1, flexShrink: 0, color: '#4ade80' }}><step.IconComp size={15} /></span>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                    <span style={{ fontSize: 12, fontWeight: 600, color: '#e6edf3' }}>{step.label}</span>
                    {step.status === 'running' && <SpinnerIcon size={11} />}
                    {step.status === 'done' && <span style={{ color: '#4ade80' }}><CheckIcon size={11} /></span>}
                  </div>
                  <p style={{ fontSize: 11, color: '#8b949e', margin: 0 }}>{step.detail}</p>
                </div>
                <span style={{ fontSize: 10, color: step.status === 'done' ? '#4ade80' : '#22c55e', fontWeight: 600 }}>
                  {step.status === 'done' ? 'Done' : 'Running'}
                </span>
              </div>
            ))}
          </div>
          {/* Progress bar */}
            <div style={{ marginTop: 10, height: 3, borderRadius: 3, background: 'rgba(74, 222, 128, 0.15)', overflow: 'hidden' }}>
            <div style={{
              height: '100%',
              borderRadius: 3,
              background: 'linear-gradient(90deg, #22c55e, #059669)',
              width: completed
                ? '100%'
                : `${Math.min(100, (visibleSteps.filter(s => s.status === 'done').length / PROBLEM_AGENT_STEPS.length) * 100 + 8)}%`,
              transition: 'width 1s ease',
            }} />
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       FINDING ITEM
       ═══════════════════════════════════════════════ */

    function FindingItem({ finding, index, decision, onApprove, onReject }) {
      const sev = (finding.severity || 'low').toLowerCase();
      const type = (finding.type || 'style').toLowerCase();

      return (
        <div className="finding-card severity-${sev} bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#21262d]">
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 12 }}>
            <div style={{ flex: 1, minWidth: 0 }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 6, marginBottom: 8, flexWrap: 'wrap' }}>
                <span className={`type-badge type-${type}`}>{finding.type || 'General'}</span>
                <span className={`sev-badge sev-${sev}`}>{finding.severity || 'low'}</span>
              </div>
              <p className="text-gray-900 dark:text-[#e6edf3]" style={{ fontSize: 13, lineHeight: 1.5, margin: '0 0 10px 0' }}>
                {finding.message}
              </p>
              {finding.suggestion && (
                <div className="bg-white dark:bg-[#0d1117] border border-gray-200 dark:border-[#21262d]" style={{ borderRadius: 8, padding: '10px 12px' }}>
                  <p className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: 10, fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 4px 0' }}>
                    Suggestion
                  </p>
                  <p style={{ fontSize: 12, color: '#7ee787', fontFamily: "'JetBrains Mono', monospace", margin: 0, lineHeight: 1.5 }}>
                    {finding.suggestion}
                  </p>
                </div>
              )}
            </div>
            <div className="toggle-group" style={{ flexShrink: 0 }}>
              <button
                className={`toggle-btn ${decision === 'approved' ? 'approved' : ''}`}
                onClick={() => onApprove(index)}
                title="Approve"
              >
                ✓
              </button>
              <button
                className={`toggle-btn ${decision === 'rejected' ? 'rejected' : ''}`}
                onClick={() => onReject(index)}
                title="Reject"
              >
                ✕
              </button>
            </div>
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       FINDINGS LIST
       ═══════════════════════════════════════════════ */

    function FindingsList({ findings, decisions, onApprove, onReject, onApproveAll, onRejectAll }) {
      if (!findings || findings.length === 0) {
        return (
          <div className="empty-state">
            <ListIcon size={40} />
            <p>No findings yet. Run a code review to see agent findings here.</p>
          </div>
        );
      }

      const approvedCount = Object.values(decisions).filter(d => d === 'approved').length;
      const rejectedCount = Object.values(decisions).filter(d => d === 'rejected').length;

      return (
        <div>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 14 }}>
            <div>
              <span style={{ fontSize: 11, fontWeight: 600, color: '#8b949e', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                {findings.length} findings
              </span>
              <span style={{ fontSize: 11, color: '#484f58', margin: '0 6px' }}>·</span>
              <span style={{ fontSize: 11, color: '#3fb950', fontWeight: 600 }}>{approvedCount} approved</span>
              <span style={{ fontSize: 11, color: '#484f58', margin: '0 6px' }}>·</span>
              <span style={{ fontSize: 11, color: '#f85149', fontWeight: 600 }}>{rejectedCount} rejected</span>
            </div>
            <div style={{ display: 'flex', gap: 6 }}>
              <button onClick={onApproveAll} className="btn-reset" style={{ padding: '3px 10px', fontSize: 11 }}>
                Approve All
              </button>
              <button onClick={onRejectAll} className="btn-reset" style={{ padding: '3px 10px', fontSize: 11 }}>
                Reject All
              </button>
            </div>
          </div>
          {findings.map((f, i) => (
            <FindingItem
              key={i}
              finding={f}
              index={i}
              decision={decisions[i]}
              onApprove={onApprove}
              onReject={onReject}
            />
          ))}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       DIFF VIEWER
       ═══════════════════════════════════════════════ */

    function DiffViewer({ diffData }) {
      if (!diffData) {
        return (
          <div className="empty-state">
            <DiffIcon size={40} />
            <p>The refactored code diff will appear here after you commit approved changes.</p>
          </div>
        );
      }

      const { original_code, final_code, diff } = diffData;

      const leftLines = [];
      const rightLines = [];
      let leftNum = 1;
      let rightNum = 1;

      (diff || []).forEach((change) => {
        const lines = change.value.replace(/\n$/, '').split('\n');
        lines.forEach((line) => {
          if (change.removed) {
            leftLines.push({ num: leftNum++, text: line, type: 'removed' });
            rightLines.push({ num: null, text: '', type: 'empty' });
          } else if (change.added) {
            leftLines.push({ num: null, text: '', type: 'empty' });
            rightLines.push({ num: rightNum++, text: line, type: 'added' });
          } else {
            leftLines.push({ num: leftNum++, text: line, type: 'unchanged' });
            rightLines.push({ num: rightNum++, text: line, type: 'unchanged' });
          }
        });
      });

      const stats = (diff || []).reduce((acc, change) => {
        const count = change.value.replace(/\n$/, '').split('\n').length;
        if (change.added) acc.added += count;
        else if (change.removed) acc.removed += count;
        return acc;
      }, { added: 0, removed: 0 });

      function renderPane(lines, title, dotColor) {
        return (
          <div className="diff-pane">
            <div className="diff-header bg-gray-50 dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d]">
              <span style={{ width: 7, height: 7, borderRadius: '50%', background: dotColor }} />
              <span className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: 11, fontWeight: 600, textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                {title}
              </span>
            </div>
            <div style={{ flex: 1, overflowY: 'auto' }}>
              {lines.map((line, i) => (
                <div key={i} className={`diff-line ${line.type}`}>
                  <span className="diff-num" style={{ color: line.type === 'removed' ? '#f8514966' : line.type === 'added' ? '#3fb95066' : '#484f58' }}>
                    {line.num || ''}
                  </span>
                  <span className="diff-prefix" style={{ color: line.type === 'removed' ? '#f85149' : line.type === 'added' ? '#3fb950' : '#30363d' }}>
                    {line.type === 'removed' ? '−' : line.type === 'added' ? '+' : ' '}
                  </span>
                  <span className="diff-text" style={{ color: line.type === 'removed' ? '#ffa198' : line.type === 'added' ? '#7ee787' : '#e6edf3' }}>
                    {line.text}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      }

      return (
        <div style={{ display: 'flex', flexDirection: 'column', height: '100%' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12, marginBottom: 12 }}>
            <span className="stat-chip" style={{ color: '#3fb950' }}>+{stats.added}</span>
            <span className="stat-chip" style={{ color: '#f85149' }}>−{stats.removed}</span>
            <span style={{ fontSize: 12, color: '#484f58' }}>lines changed</span>
          </div>
          <div style={{ display: 'flex', flex: 1, border: '1px solid #21262d', borderRadius: 10, overflow: 'hidden', minHeight: 0 }}>
            {renderPane(leftLines, 'Original', '#f85149')}
            <div style={{ width: 1, background: '#21262d' }} />
            {renderPane(rightLines, 'Refactored', '#3fb950')}
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       APP (Main Container)
       ═══════════════════════════════════════════════ */

    function Sidebar({ sessions, activeSessionId, onSelectSession, onCreateSession, isOpen }) {
      const sortedSessions = [...sessions].sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));

      return (
        <div className="bg-white dark:bg-[#0d1117] border-r border-gray-200 dark:border-[#21262d] transition-colors duration-200" style={{ display: 'flex', flexDirection: 'column', height: '100%', width: '100%', transition: 'width 0.2s ease, background-color 0.2s, border-color 0.2s' }}>
          <div className="border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200" style={{ padding: '16px', textAlign: 'center' }}>
            <button onClick={onCreateSession} className="bg-gray-100 text-gray-900 dark:bg-[#0d1117] dark:text-[#e6edf3] hover:bg-gray-200 dark:hover:bg-[#161b22] transition-colors duration-200" style={{ width: '100%', justifyContent: 'center', padding: '6px 16px', borderRadius: '8px', fontSize: '13px', fontWeight: '600', border: 'none', cursor: 'pointer', display: 'flex', alignItems: 'center' }}>
              {isOpen ? '+ New Session' : '+'}
            </button>
          </div>
          <div style={{ flex: 1, overflowY: 'auto' }}>
            {sortedSessions.map(session => (
              <div 
                key={session.id} 
                onClick={() => onSelectSession(session.id)}
                title={session.title}
                className={activeSessionId === session.id ? 'bg-gray-100 dark:bg-[#161b22]' : 'hover:bg-gray-50 dark:hover:bg-[#161b22] transition-colors duration-200'}
                style={{ 
                  padding: isOpen ? '12px 16px' : '12px 0', cursor: 'pointer', borderBottom: '1px solid var(--border-color)',
                  borderLeft: activeSessionId === session.id ? '3px solid #4ade80' : '3px solid transparent',
                  textAlign: isOpen ? 'left' : 'center'
                }}
              >
                {isOpen ? (
                  <>
                    <div className="text-gray-700 dark:text-[#e6edf3]" style={{ fontSize: '13px', fontWeight: '600', marginBottom: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                      {session.title}
                    </div>
                    <div className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: '11px' }}>
                      {new Date(session.updatedAt).toLocaleDateString()}
                    </div>
                  </>
                ) : (
                  <div className="text-gray-700 dark:text-[#e6edf3]" style={{ fontSize: '12px', fontWeight: 'bold' }}>
                    {session.title.substring(0, 2).toUpperCase()}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      );
    }

    function App() {
      const [inputCode, setInputCode] = useState('');
      const [loading, setLoading] = useState(false);
      const [status, setStatus] = useState('idle');
      const [logs, setLogs] = useState([]);
      const [findings, setFindings] = useState([]);
      const [decisions, setDecisions] = useState({});
      const [threadId, setThreadId] = useState(null);
      const [finalCode, setFinalCode] = useState('');
      const [diffData, setDiffData] = useState(null);
      const [error, setError] = useState(null);
      const [activeTab, setActiveTab] = useState('logs');
      const [sessions, setSessions] = useState([]);
      const [activeSessionId, setActiveSessionId] = useState(null);
      const [problemDescription, setProblemDescription] = useState('');
      const [problemAnalysis, setProblemAnalysis] = useState(null);
      const [constraintInsights, setConstraintInsights] = useState(null);
      const [expectedTC, setExpectedTC] = useState('');
      const [expectedSC, setExpectedSC] = useState('');
      const [complexityReasoning, setComplexityReasoning] = useState('');
      const [detectedPattern, setDetectedPattern] = useState('');
      const [patternConfidence, setPatternConfidence] = useState(0);
      const [strategyPlan, setStrategyPlan] = useState(null);
      const [testCaseValidation, setTestCaseValidation] = useState(null);
      const [analysisStatus, setAnalysisStatus] = useState('IDLE');
      const [problemTitle, setProblemTitle] = useState('');

      const [analyzingProblem, setAnalyzingProblem] = useState(false);
      const [problemAnalysisDone, setProblemAnalysisDone] = useState(false);
      const [sidebarOpen, setSidebarOpen] = useState(true);
      const [theme, setTheme] = useState(() => {
        return localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      });

      useEffect(() => {
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
        localStorage.setItem("theme", theme);
      }, [theme]);

      function toggleTheme() {
        setTheme(prev => prev === "dark" ? "light" : "dark");
      }

      useEffect(() => {
        fetch('/sessions').then(r => r.json()).then(data => {
          setSessions(data);
          if (data.length > 0 && !activeSessionId) setActiveSessionId(data[data.length-1].id);
        }).catch(err => console.error(err));
      }, []);

      const handleSelectSession = useCallback((id) => {
        setActiveSessionId(id);
        fetch(`/sessions/${id}`)
          .then(r => {
             if (!r.ok) throw new Error("Session not found");
             return r.json();
          })
          .then(data => {
            setThreadId(id);
            
            // Sync editor with session codebase
            const contextHistory = data.context || [];
            const lastCodeEntry = contextHistory.filter(c => c.type === 'code').pop();
            
            setInputCode(lastCodeEntry ? lastCodeEntry.content : '');
            setProblemDescription(data.problem_description || '');
            setProblemAnalysis(data.problem_analysis || null);
            setProblemTitle(data.title || '');
            setConstraintInsights(data.constraint_insights || null);
            setExpectedTC(data.expected_time_complexity || '');
            setExpectedSC(data.expected_space_complexity || '');
            setComplexityReasoning(data.complexity_reasoning || '');
            setDetectedPattern(data.detected_pattern || '');
            setPatternConfidence(data.pattern_confidence || 0);
            setStrategyPlan(data.strategy_plan || null);
            setTestCaseValidation(data.test_case_validation || null);
            setAnalysisStatus(data.analysis_status || 'IDLE');
            setFindings([]);
            setStatus('idle');
            setLogs([]);
            setDiffData(null);
            setFinalCode('');
          })
          .catch(err => {
             console.error("Session switch error:", err);
             setError("Failed to load session context");
          });
      }, []);

      const handleCreateSession = useCallback(() => {
        fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) })
          .then(r => r.json())
          .then(newSession => {
             setSessions(prev => [...prev, newSession]);
             setActiveSessionId(newSession.id);
             setThreadId(newSession.id);
             setInputCode('');
             setProblemDescription('');
             setProblemTitle('');
             setProblemAnalysis(null);
             setConstraintInsights(null);
             setExpectedTC('');
             setExpectedSC('');
             setComplexityReasoning('');
             setDetectedPattern('');
             setPatternConfidence(0);
             setStrategyPlan(null);
             setTestCaseValidation(null);
             setAnalysisStatus('IDLE');
             setFindings([]);
             setDecisions({});
             setStatus('idle');
             setLogs([]);
             setDiffData(null);
             setFinalCode('');
             setError(null);
          });
      }, []);



      const handleAnalyzeProblem = useCallback(async () => {
        if (!problemDescription.trim()) return;
        setAnalyzingProblem(true);
        setProblemAnalysisDone(false);
        setError(null);
        try {
          // Auto-create session if none exists
          let currentSessionId = activeSessionId;
          if (!currentSessionId) {
            const sessionRes = await fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) });
            const newSession = await sessionRes.json();
            setSessions(prev => [...prev, newSession]);
            currentSessionId = newSession.id;
            setActiveSessionId(currentSessionId);
            setThreadId(currentSessionId);
          }

          const res = await fetch(`/sessions/${currentSessionId}/problem/analyze`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ problem_description: problemDescription })
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);
          if (data.problem_analysis) {
            setProblemAnalysis(data.problem_analysis);
            setConstraintInsights(data.constraint_insights);
            setExpectedTC(data.expected_time_complexity);
            setExpectedSC(data.expected_space_complexity);
            setComplexityReasoning(data.complexity_reasoning);
            setDetectedPattern(data.detected_pattern);
            setPatternConfidence(data.pattern_confidence);
            setStrategyPlan(data.strategy_plan);
            setTestCaseValidation(data.test_case_validation);
          }
          // Capture AI-generated problem title
          if (data.problem_title) {
            setProblemTitle(data.problem_title);
            // Update session title in sidebar
            setSessions(prev => prev.map(s => 
              s.id === currentSessionId ? { ...s, title: data.problem_title } : s
            ));
          }
          if (data.status) {
             setAnalysisStatus(data.status);
          }
          setProblemAnalysisDone(true);
          // Auto-scroll decision buttons into view after short delay
          setTimeout(() => {
            const decisionEl = document.getElementById('decision-panel');
            if (decisionEl) decisionEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 300);
        } catch (err) {
          setError('Problem analysis failed: ' + err.message);
        } finally {
          setAnalyzingProblem(false);
        }
      }, [activeSessionId, problemDescription]);

      const handleDecision = useCallback(async (decision) => {
        if (!activeSessionId) return;
        setAnalysisStatus('LOADING_DECISION');
        try {
          const res = await fetch(`/sessions/${activeSessionId}/problem/decision`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ decision })
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);
          if (data.status) {
             setAnalysisStatus(data.status);
          }
          if (decision === 'generate' && data.input_code) {
             // Place generated code in editor and auto-trigger code review
             setInputCode(data.input_code);
             // Small delay to let state update, then auto-analyze
             setTimeout(() => {
               handleAnalyzeGenerated(data.input_code);
             }, 500);
          } else if (decision === 'manual') {
             // Switch focus to problem tab — user writes code then clicks Analyze Code
             setActiveTab('problem');
          } else if (decision === 'hints') {
             // Hints mode — strategy is already shown
             setActiveTab('problem');
          }
        } catch (err) {
          alert('Error submitting decision: ' + err.message);
          setAnalysisStatus('PENDING_DECISION');
        }
      }, [activeSessionId]);

      const handleApproveItem = useCallback((index) => {
        setDecisions(prev => ({
          ...prev,
          [index]: prev[index] === 'approved' ? undefined : 'approved'
        }));
      }, []);

      const handleRejectItem = useCallback((index) => {
        setDecisions(prev => ({
          ...prev,
          [index]: prev[index] === 'rejected' ? undefined : 'rejected'
        }));
      }, []);

      const handleApproveAll = useCallback(() => {
        setDecisions(prev => {
          const next = {};
          findings.forEach((_, i) => { next[i] = 'approved'; });
          return next;
        });
      }, [findings]);

      const handleRejectAll = useCallback(() => {
        setDecisions(prev => {
          const next = {};
          findings.forEach((_, i) => { next[i] = 'rejected'; });
          return next;
        });
      }, [findings]);

      // Auto-analyze generated code (called after code generation)
      async function handleAnalyzeGenerated(code) {
        if (!code || !code.trim()) return;
        setStatus('loading');
        setLoading(true);
        setError(null);
        setFindings([]);
        setDecisions({});
        setDiffData(null);
        setFinalCode('');
        setActiveTab('logs');

        try {
          let currentSessionId = activeSessionId;
          const res = await fetch(`/sessions/${currentSessionId}/input`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'code', content: code, input_code: code }),
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);
          if (data.thread_id) setThreadId(data.thread_id);
          const report = data.aggregated_report || data.findings || [];
          setFindings(report);
          const initialDecisions = {};
          report.forEach((_, i) => { initialDecisions[i] = 'approved'; });
          setDecisions(initialDecisions);
          setLoading(false);
          setStatus('pending');
          setActiveTab('findings');
        } catch (err) {
          setError(err.message);
          setLoading(false);
          setStatus('error');
        }
      }

      async function handleAnalyze() {
        if (!inputCode.trim()) return;
        setStatus('loading');
        setLoading(true);
        setError(null);
        setFindings([]);
        setDecisions({});
        setDiffData(null);
        setFinalCode('');
        setActiveTab('logs');

        try {
          let currentSessionId = activeSessionId;
          
          if (!currentSessionId) {
             const res = await fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) });
             const newSession = await res.json();
             setSessions(prev => [...prev, newSession]);
             currentSessionId = newSession.id;
             setActiveSessionId(currentSessionId);
             setThreadId(currentSessionId);
          }

          const res = await fetch(`/sessions/${currentSessionId}/input`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'code', content: inputCode, input_code: inputCode }),
          });
          const data = await res.json();

          if (data.error) throw new Error(data.error);

          // Store the review thread_id from Python for approval
          if (data.thread_id) {
            setThreadId(data.thread_id);
          }

          const report = data.aggregated_report || data.findings || [];
          setFindings(report);

          const initialDecisions = {};
          report.forEach((_, i) => { initialDecisions[i] = 'approved'; });
          setDecisions(initialDecisions);

          setLoading(false);
          setStatus('pending');
          setActiveTab('findings');
        } catch (err) {
          setError(err.message);
          setLoading(false);
          setStatus('error');
        }
      }

      async function handleCommit() {
        const approved = findings.filter((_, i) => decisions[i] === 'approved');
        if (approved.length === 0) return;

        setStatus('approving');
        setError(null);

        try {
          // Use session-aware approval endpoint which uses stored review_thread_id
          const endpoint = activeSessionId 
            ? `/sessions/${activeSessionId}/review/approve`
            : '/review/approve';
          
          const body = activeSessionId
            ? { approved_suggestions: approved }
            : { thread_id: threadId, approved_suggestions: approved };

          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          const data = await res.json();

          if (data.error) throw new Error(data.error);

          setFinalCode(data.final_code || data.diffData?.final_code || '');
          setDiffData(data.diffData || null);
          setStatus('completed');
          setActiveTab('results');
        } catch (err) {
          setError(err.message);
          setStatus('error');
        }
      }

      function handleReset() {
        setInputCode('');
        setLoading(false);
        setStatus('idle');
        setLogs([]);
        setFindings([]);
        setDecisions({});
        setThreadId(null);
        setFinalCode('');
        setDiffData(null);
        setError(null);
        setActiveTab('logs');
        setProblemDescription('');
        setProblemAnalysis(null);
        setConstraintInsights(null);
        setExpectedTC('');
        setExpectedSC('');
        setComplexityReasoning('');
        setDetectedPattern('');
        setPatternConfidence(0);
        setStrategyPlan(null);
        setTestCaseValidation(null);
        setAnalysisStatus('IDLE');
      }

      // Re-run review on updated code without resetting analysis state
      async function handleImproveCode() {
        if (!inputCode.trim() || !activeSessionId) return;
        setStatus('loading');
        setLoading(true);
        setError(null);
        setFindings([]);
        setDecisions({});
        setDiffData(null);
        setFinalCode('');
        setActiveTab('logs');

        try {
          const res = await fetch(`/sessions/${activeSessionId}/input`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'code', content: inputCode, input_code: inputCode }),
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);

          if (data.thread_id) setThreadId(data.thread_id);

          const report = data.aggregated_report || data.findings || [];
          setFindings(report);
          const initialDecisions = {};
          report.forEach((_, i) => { initialDecisions[i] = 'approved'; });
          setDecisions(initialDecisions);

          setLoading(false);
          setStatus('pending');
          setActiveTab('findings');
        } catch (err) {
          setError(err.message);
          setLoading(false);
          setStatus('error');
        }
      }

      const approvedCount = Object.values(decisions).filter(d => d === 'approved').length;
      const canCommit = status === 'pending' && approvedCount > 0;
      const canAnalyze = (status === 'idle' || status === 'error') && inputCode.trim().length > 0;
      const isAnalyzeDisabled = !canAnalyze || status === 'loading';

      const findingsTabLabel = findings.length > 0 ? `Findings (${findings.length})` : 'Findings';

      useEffect(() => {
        function handleKeyDown(e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            if (canAnalyze) handleAnalyze();
          }
        }
        window.addEventListener('keydown', handleKeyDown);
        return () => window.removeEventListener('keydown', handleKeyDown);
      }, [canAnalyze, inputCode]);

      return (
        <div className="app-shell">
          {/* ── HEADER BAR ── */}
          <div className="header-bar bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200 text-black dark:text-[#e6edf3]">
            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              <button 
                onClick={() => setSidebarOpen(prev => !prev)}
                className="text-gray-800 dark:text-[#e6edf3]"
                style={{ background: 'transparent', border: 'none', cursor: 'pointer', fontSize: 18, padding: '0 4px', marginRight: '4px' }}
              >
                <MenuIcon size={18} />
              </button>
              <div style={{
                width: 28, height: 28, borderRadius: 7,
                background: 'linear-gradient(135deg, #22c55e, #059669)',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
                boxShadow: '0 0 12px rgba(34, 197, 94, 0.3)',
              }}>
                <ShieldIcon size={16} />
              </div>
              <span style={{ fontSize: 14, fontWeight: 700, letterSpacing: '-0.01em' }}>
                Sentinel-Graph
              </span>
            </div>
            <div style={{ flex: 1 }} />
            
            <button 
              onClick={toggleTheme} 
              className="mr-3 flex items-center justify-center p-1.5 rounded-md bg-gray-200 dark:bg-[#21262d] text-gray-800 dark:text-[#e6edf3] hover:bg-gray-300 dark:hover:bg-[#30363d] transition-colors duration-200"
              title="Toggle Light/Dark Theme"
            >
              {theme === 'dark' ? <SunIcon size={16} /> : <MoonIcon size={16} />}
            </button>

            <StatusBadge status={status} />
            {error && (
              <div style={{
                display: 'flex', alignItems: 'center', gap: 6,
                background: 'rgba(248,81,73,0.1)', padding: '3px 10px',
                borderRadius: 6, fontSize: 11, color: '#f85149', fontWeight: 500,
                maxWidth: 300, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap'
              }}>
                <span style={{ display: 'inline-flex', alignItems: 'center' }}><AlertTriangleIcon size={12} /></span> {error}
              </div>
            )}
          </div>

          {/* ── MAIN AREA ── */}
          <div className="main-area bg-white dark:bg-[#0d1117] text-black dark:text-[#e6edf3] transition-colors duration-200" style={{ flex: 1, display: 'flex' }}>
            {PanelGroup ? (
              <>
                <div style={{ width: sidebarOpen ? '0px' : '60px', transition: 'width 0.2s ease', flexShrink: 0, overflow: 'hidden' }}>
                  {!sidebarOpen && (
                    <Sidebar 
                      sessions={sessions} 
                      activeSessionId={activeSessionId} 
                      onSelectSession={handleSelectSession} 
                      onCreateSession={handleCreateSession} 
                      isOpen={false}
                    />
                  )}
                </div>
                <PanelGroup direction="horizontal" autoSaveId="sentinel-layout-main" style={{ flex: 1 }}>
                  {/* LEFT: Sidebar Panel */}
                  {sidebarOpen && (
                    <>
                      <Panel defaultSize={20} minSize={10} id="sidebar-panel">
                        <Sidebar 
                          sessions={sessions} 
                          activeSessionId={activeSessionId} 
                          onSelectSession={handleSelectSession} 
                          onCreateSession={handleCreateSession} 
                          isOpen={true}
                        />
                      </Panel>
                      <ResizeHandle />
                    </>
                  )}

                  {/* CENTER: Code Editor Panel */}
                  <Panel defaultSize={40} minSize={20} id="editor-panel">
                    <div className="editor-pane">
                    <div className="pane-header bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                      <svg width={14} height={14} viewBox="0 0 24 24" fill="none" stroke="currentColor" className="text-gray-500 dark:text-[#8b949e]" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
                        <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                      </svg>
                      <span className="text-gray-500 dark:text-[#8b949e]">Editor</span>
                      <div style={{ flex: 1 }} />
                      <span className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: 10, fontFamily: "'JetBrains Mono', monospace" }}>
                        {inputCode.split('\n').length} lines
                      </span>
                    </div>
                    <Editor
                      key={theme}
                      theme={theme === "dark" ? "vs-dark" : "light"}
                      value={inputCode}
                      onChange={setInputCode}
                      disabled={status === 'loading' || status === 'approving'}
                    />
                  </div>
                </Panel>

                 <ResizeHandle />

                {/* RIGHT: Tools Panel Split */}
                <Panel defaultSize={40} minSize={25} id="right-panel">
                  <PanelGroup direction="vertical" autoSaveId="sentinel-layout-right">
                    {/* Tools Panel TOP: Logs/Findings */}
                    <Panel defaultSize={50} minSize={20} id="findings-panel">
                      <div className="right-pane bg-gray-50 dark:bg-[#0d1117]">
                        <div className="tab-strip bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                          <button className={`tab-btn ${activeTab === 'problem' ? 'active' : ''}`} onClick={() => setActiveTab('problem')}>Problem Input</button>
