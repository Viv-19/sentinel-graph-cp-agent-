                                  )}
                                  {strategyPlan.edge_case_plan?.length > 0 && (
                                    <div className="mt-1 text-xs">
                                      <strong>Edge Cases to Handle:</strong> {strategyPlan.edge_case_plan.join(" | ")}
                                    </div>
                                  )}
                                  <p className="italic text-[11px] opacity-80 mt-2">{strategyPlan.justification}</p>
                                </div>
                              </div>
                            )}

                            {testCaseValidation && (
                              <div style={{ marginTop: '12px', borderTop: '1px solid rgba(128,128,128,0.2)', paddingTop: '12px' }}>
                                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                                  <strong className="text-gray-900 dark:text-[#e6edf3]">5. Simulation & Validation</strong>
                                  <span style={{ fontSize: '10px' }} className={`px-2 py-0.5 rounded font-bold uppercase ${testCaseValidation.passes_sample_tests ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                                    {testCaseValidation.passes_sample_tests ? 'PASS' : 'FAIL'}
                                  </span>
                                </div>
                                <div className="mt-2 text-gray-700 dark:text-[#8b949e]">
                                  <div style={{ display: 'flex', gap: '8px', marginBottom: '8px' }}>
                                    <span className="px-2 py-0.5 bg-gray-200 dark:bg-[#30363d] text-gray-800 dark:text-[#e6edf3] rounded text-[10px] uppercase font-bold">
                                      Mode: {testCaseValidation.validation_mode}
                                    </span>
                                    <span className="px-2 py-0.5 bg-gray-200 dark:bg-[#30363d] text-gray-800 dark:text-[#e6edf3] rounded text-[10px] uppercase font-bold">
                                      Conf: {Math.round(testCaseValidation.confidence_score * 100)}%
                                    </span>
                                  </div>
                                  {testCaseValidation.edge_case_analysis?.length > 0 && (
                                    <div className="mt-2 text-xs">
                                      <strong>Edge Cases:</strong>
                                      <ul className="pl-4 list-disc">
                                        {testCaseValidation.edge_case_analysis.map((e, i) => <li key={i}>{e}</li>)}
                                      </ul>
                                    </div>
                                  )}
                                </div>
                              </div>
                            )}

                            {/* Decision Buttons */}
                            {analysisStatus === 'PENDING_DECISION' && (
                              <div id="decision-panel" style={{ marginTop: '16px', padding: '16px', background: 'rgba(74, 222, 128, 0.08)', border: '2px solid rgba(74, 222, 128, 0.3)', borderRadius: '10px', textAlign: 'center' }}>
                                <h3 style={{ color: '#4ade80', fontWeight: 700, marginBottom: '12px', fontSize: '14px' }}>Analysis Complete — Choose Your Path</h3>
                                <p style={{ color: '#8b949e', fontSize: '12px', marginBottom: '14px' }}>The strategy and approach are ready. How would you like to proceed?</p>
                                <div style={{ display: 'flex', gap: '10px', justifyContent: 'center', flexWrap: 'wrap' }}>
                                  <button onClick={() => handleDecision('generate')} className="btn-primary btn-analyze" style={{ padding: '8px 20px', fontSize: '13px' }}>
                                    <ZapIcon size={14} /> Generate Code
                                  </button>
                                  <button onClick={() => handleDecision('manual')} className="btn-primary btn-commit" style={{ padding: '8px 20px', fontSize: '13px' }}>
                                    <PenIcon size={14} /> Write My Own
                                  </button>
                                  <button onClick={() => handleDecision('hints')} className="btn-reset" style={{ padding: '8px 16px', fontSize: '13px' }}>
                                    <LightbulbIcon size={14} /> Just Show Hints
                                  </button>
                                </div>
                              </div>
                            )}
                            {analysisStatus === 'LOADING_DECISION' && (
                              <div style={{ marginTop: '16px', textAlign: 'center', color: '#4ade80', fontSize: '12px', fontStyle: 'italic', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8 }}>
                                <SpinnerIcon size={14} /> Processing your decision...
                              </div>
                            )}
                            {analysisStatus === 'RESUMED' && (
                              <div style={{ marginTop: '16px', padding: '12px', background: 'rgba(74, 222, 128, 0.08)', border: '1px solid rgba(74, 222, 128, 0.2)', borderRadius: '8px', textAlign: 'center', color: '#4ade80', fontSize: '12px', fontWeight: 'bold', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 6 }}>
                                <CheckCircleIcon size={14} /> {inputCode ? 'Code generated and loaded into editor. Running code review agents...' : 'Graph resumed — write your code in the editor, then click Analyze Code.'}
                              </div>
                            )}
                          </div>
                        ) : analyzingProblem ? (
                          <div className="bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-3 rounded" style={{ fontSize: '12px', overflowY: 'auto', flex: 1 }}>
                            <ProblemAgentTracker running={analyzingProblem} completed={false} />
                          </div>
                        ) : (
                          <div className="text-gray-500 dark:text-[#8b949e] flex items-center justify-center border border-dashed border-gray-300 dark:border-[#30363d] rounded p-4" style={{ flex: 1, fontSize: '12px', textAlign: 'center' }}>
                            No analysis yet. Click "Analyze Problem" to process.
                          </div>
                        )}
                      </div>
                    )}
                    {activeTab === 'logs' && <LogsPanel loading={status === 'loading'} completed={status === 'pending' || status === 'completed' || status === 'approving'} />}
                    {activeTab === 'findings' && <FindingsList findings={findings} decisions={decisions} onApprove={handleApproveItem} onReject={handleRejectItem} onApproveAll={handleApproveAll} onRejectAll={handleRejectAll} />}
                    {activeTab === 'results' && <DiffViewer diffData={diffData} />}
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* ── ACTION BAR ── */}
          <div className="action-bar">
            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              {(status === 'pending' || status === 'completed') && (
                <button className="btn-reset text-gray-900 dark:text-white" onClick={handleReset}>
                  <RefreshIcon size={12} />
                  New Review
                </button>
              )}
              {status === 'completed' && activeSessionId && (
                <button 
                  className="btn-reset text-gray-900 dark:text-white"
                  onClick={handleImproveCode}
                  style={{ background: 'rgba(74, 222, 128, 0.15)', borderColor: '#4ade80' }}
                >
                  <ZapIcon size={12} />
                  Improve My Code
                </button>
              )}
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              {status === 'pending' && (
                <span style={{ fontSize: 12, color: '#8b949e' }}>
                  <span style={{ color: '#3fb950', fontWeight: 600 }}>{approvedCount}</span> approved
                </span>
              )}
              <button
                className="btn-primary btn-analyze"
                onClick={handleAnalyze}
                disabled={isAnalyzeDisabled}
                style={{ display: status === 'pending' || status === 'approving' || status === 'completed' ? 'none' : 'inline-flex' }}
                title="Ctrl+Enter"
              >
                {status === 'loading' ? (
                  <><SpinnerIcon size={14} /> Analyzing...</>
                ) : (
                  <><ZapIcon size={14} /> Analyze Code</>
                )}
              </button>
              <button
                className="btn-primary btn-commit"
                onClick={handleCommit}
                disabled={!canCommit}
                style={{ display: status === 'pending' || status === 'approving' ? 'inline-flex' : 'none' }}
              >
                {status === 'approving' ? (
                  <><SpinnerIcon size={14} /> Committing...</>
                ) : (
                  <><CheckIcon size={14} /> Commit Changes</>
                )}
              </button>
            </div>
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       MOUNT
       ═══════════════════════════════════════════════ */

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(
      <ErrorBoundary>
        <App />
      </ErrorBoundary>
    );
  </script>
</body>
</html>
