<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sentinel-Graph — AI Code Review</title>
  <meta name="description" content="AI-powered multi-agent code review system with human-in-the-loop approval workflow">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
        },
      },
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body, #root { height: 100%; margin: 0; overflow: hidden; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #0d1117; color: #e6edf3; }

    .app-shell {
      display: grid;
      grid-template-rows: 48px 1fr 56px;
      height: 100vh;
      background: #0d1117;
    }

    .header-bar {
      background: #161b22;
      border-bottom: 1px solid #21262d;
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 12px;
      z-index: 50;
    }

    .main-area {
      display: grid;
      grid-template-columns: 250px 1fr 1fr;
      overflow: hidden;
    }

    .editor-pane {
      border-right: 1px solid #21262d;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .right-pane {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: #0d1117;
    }

    .action-bar {
      background: #161b22;
      border-top: 1px solid #21262d;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      z-index: 50;
    }

    .tab-strip {
      display: flex;
      background: #161b22;
      border-bottom: 1px solid #21262d;
      padding: 0 4px;
      flex-shrink: 0;
    }

    .tab-btn {
      padding: 8px 16px;
      font-size: 12px;
      font-weight: 500;
      color: #8b949e;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      transition: all 0.15s ease;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }
    .tab-btn:hover { color: #e6edf3; }
    .tab-btn.active {
      color: #e6edf3;
      border-bottom-color: #58a6ff;
    }

    .tab-content {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
    }

    .tab-content::-webkit-scrollbar { width: 6px; }
    .tab-content::-webkit-scrollbar-track { background: transparent; }
    .tab-content::-webkit-scrollbar-thumb { background: #30363d; border-radius: 3px; }
    .tab-content::-webkit-scrollbar-thumb:hover { background: #484f58; }

    .pane-header {
      display: flex;
      align-items: center;
      padding: 0 12px;
      height: 36px;
      background: #161b22;
      border-bottom: 1px solid #21262d;
      flex-shrink: 0;
      gap: 8px;
    }
    .pane-header span {
      font-size: 11px;
      font-weight: 600;
      color: #8b949e;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    #monaco-container {
      flex: 1;
      min-height: 0;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.03em;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: all 0.15s ease;
      color: #fff;
    }
    .btn-primary:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .btn-analyze {
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
    }
    .btn-analyze:not(:disabled):hover {
      background: linear-gradient(135deg, #818cf8, #a78bfa);
      box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
    }

    .btn-commit {
      background: linear-gradient(135deg, #10b981, #059669);
    }
    .btn-commit:not(:disabled):hover {
      background: linear-gradient(135deg, #34d399, #10b981);
      box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
    }

    .btn-reset {
      background: transparent;
      border: 1px solid #30363d;
      color: #8b949e;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .btn-reset:hover {
      border-color: #484f58;
      color: #e6edf3;
    }

    .log-entry {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 8px 12px;
      border-radius: 8px;
      margin-bottom: 4px;
      font-size: 13px;
      animation: logFadeIn 0.3s ease-out forwards;
      opacity: 0;
    }
    .log-entry.done { background: rgba(16, 185, 129, 0.06); }
    .log-entry.running { background: rgba(99, 102, 241, 0.06); }
    .log-entry.waiting { background: transparent; }

    @keyframes logFadeIn {
      from { opacity: 0; transform: translateX(-8px); }
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    .pulse-dot { animation: pulse-dot 1.2s ease-in-out infinite; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spin-icon { animation: spin 1s linear infinite; }

    .finding-card {
      background: #161b22;
      border: 1px solid #21262d;
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 10px;
      transition: all 0.2s ease;
    }
    .finding-card:hover {
      border-color: #30363d;
      box-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .finding-card.severity-high { border-left: 3px solid #f85149; }
    .finding-card.severity-medium { border-left: 3px solid #d29922; }
    .finding-card.severity-low { border-left: 3px solid #58a6ff; }

    .sev-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .sev-high { background: rgba(248,81,73,0.15); color: #f85149; }
    .sev-medium { background: rgba(210,153,34,0.15); color: #d29922; }
    .sev-low { background: rgba(88,166,255,0.15); color: #58a6ff; }

    .type-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .type-bug { background: rgba(248,81,73,0.12); color: #ff7b72; }
    .type-style { background: rgba(88,166,255,0.12); color: #79c0ff; }
    .type-performance { background: rgba(210,153,34,0.12); color: #e3b341; }

    .toggle-group {
      display: inline-flex;
      border-radius: 6px;
      overflow: hidden;
      border: 1px solid #30363d;
    }
    .toggle-btn {
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
      background: transparent;
      color: #8b949e;
      border: none;
    }
    .toggle-btn:first-child { border-right: 1px solid #30363d; }
    .toggle-btn.approved {
      background: rgba(16, 185, 129, 0.15);
      color: #3fb950;
    }
    .toggle-btn.rejected {
      background: rgba(248, 81, 73, 0.15);
      color: #f85149;
    }

    .diff-pane {
      display: flex;
      flex: 1;
      min-width: 0;
      flex-direction: column;
    }
    .diff-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      background: #161b22;
      border-bottom: 1px solid #21262d;
      flex-shrink: 0;
    }
    .diff-line {
      display: flex;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      line-height: 20px;
      transition: background 0.1s;
    }
    .diff-line:hover { background: rgba(255,255,255,0.02); }
    .diff-line.removed { background: rgba(248,81,73,0.08); }
    .diff-line.added { background: rgba(63,185,80,0.08); }
    .diff-line.empty { background: rgba(255,255,255,0.01); }
    .diff-num {
      flex-shrink: 0;
      width: 48px;
      text-align: right;
      padding-right: 8px;
      user-select: none;
      color: #484f58;
    }
    .diff-prefix {
      flex-shrink: 0;
      width: 20px;
      text-align: center;
      user-select: none;
    }
    .diff-text {
      flex: 1;
      padding-right: 12px;
      white-space: pre;
    }

    .stat-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: #484f58;
      gap: 12px;
      text-align: center;
      padding: 40px;
    }
    .empty-state svg { opacity: 0.3; }
    .empty-state p { font-size: 13px; max-width: 280px; line-height: 1.5; }
  </style>
</head>
<body>

  <div id="root"></div>

  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <script>
    window.require = { paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' } };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>

  <script type="text/babel">
    const { useState, useEffect, useRef, useCallback } = React;

    /* ═══════════════════════════════════════════════
       ICONS (inline SVG helpers)
       ═══════════════════════════════════════════════ */

    function ShieldIcon({ size = 20 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      );
    }

    function ZapIcon({ size = 16 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
      );
    }

    function CheckIcon({ size = 14 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2.5} strokeLinecap="round" strokeLinejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      );
    }

    function RefreshIcon({ size = 14 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
          <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
        </svg>
      );
    }

    function SpinnerIcon({ size = 14 }) {
      return (
        <svg className="spin-icon" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2.5} strokeLinecap="round">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
      );
    }

    function TerminalIcon({ size = 14 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
          <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
        </svg>
      );
    }

    function ListIcon({ size = 14 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
          <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
      );
    }

    function DiffIcon({ size = 14 }) {
      return (
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
          <path d="M12 3v18"/><path d="M18 6l-6-3-6 3"/><path d="M6 18l6 3 6-3"/>
        </svg>
      );
    }

    /* ═══════════════════════════════════════════════
       STATUS BADGE
       ═══════════════════════════════════════════════ */

    function StatusBadge({ status }) {
      const map = {
        idle:      { label: 'Ready',       bg: '#21262d', color: '#8b949e', dot: '#484f58' },
        loading:   { label: 'Analyzing',   bg: 'rgba(99,102,241,0.15)', color: '#a5b4fc', dot: '#818cf8' },
        pending:   { label: 'Pending',     bg: 'rgba(210,153,34,0.15)', color: '#e3b341', dot: '#d29922' },
        approving: { label: 'Committing',  bg: 'rgba(16,185,129,0.15)', color: '#6ee7b7', dot: '#34d399' },
        completed: { label: 'Completed',   bg: 'rgba(63,185,80,0.15)',  color: '#3fb950', dot: '#3fb950' },
        error:     { label: 'Error',       bg: 'rgba(248,81,73,0.15)',  color: '#f85149', dot: '#f85149' },
      };
      const cfg = map[status] || map.idle;
      return (
        <div className="status-pill" style={{ background: cfg.bg, color: cfg.color }}>
          <span style={{ width: 6, height: 6, borderRadius: '50%', background: cfg.dot, display: 'inline-block' }}
                className={status === 'loading' || status === 'approving' ? 'pulse-dot' : ''} />
          {cfg.label}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       EDITOR COMPONENT (Monaco Wrapper)
       ═══════════════════════════════════════════════ */

    function Editor({ value, onChange, disabled }) {
      const containerRef = useRef(null);
      const editorRef = useRef(null);
      const isSettingValue = useRef(false);

      useEffect(() => {
        let disposed = false;

        require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' } });

        require(['vs/editor/editor.main'], function (monaco) {
          if (disposed || !containerRef.current) return;

          monaco.editor.defineTheme('sentinel-dark', {
            base: 'vs-dark',
            inherit: true,
            rules: [
              { token: 'comment', foreground: '6a737d', fontStyle: 'italic' },
              { token: 'keyword', foreground: 'ff7b72' },
              { token: 'string', foreground: 'a5d6ff' },
              { token: 'number', foreground: '79c0ff' },
              { token: 'type', foreground: 'ffa657' },
            ],
            colors: {
              'editor.background': '#0d1117',
              'editor.foreground': '#e6edf3',
              'editor.lineHighlightBackground': '#161b2280',
              'editor.selectionBackground': '#264f7840',
              'editorLineNumber.foreground': '#484f58',
              'editorLineNumber.activeForeground': '#8b949e',
              'editorCursor.foreground': '#58a6ff',
              'editor.inactiveSelectionBackground': '#264f7820',
              'editorIndentGuide.background': '#21262d',
              'editorIndentGuide.activeBackground': '#30363d',
            },
          });

          const editor = monaco.editor.create(containerRef.current, {
            value: value || '',
            language: 'javascript',
            theme: 'sentinel-dark',
            fontFamily: "'JetBrains Mono', monospace",
            fontSize: 13,
            lineHeight: 20,
            padding: { top: 12, bottom: 12 },
            minimap: { enabled: false },
            scrollBeyondLastLine: false,
            automaticLayout: true,
            wordWrap: 'on',
            tabSize: 2,
            renderLineHighlight: 'line',
            cursorBlinking: 'smooth',
            cursorSmoothCaretAnimation: 'on',
            smoothScrolling: true,
            bracketPairColorization: { enabled: true },
            guides: { indentation: true, bracketPairs: true },
            overviewRulerBorder: false,
            hideCursorInOverviewRuler: true,
            scrollbar: {
              verticalScrollbarSize: 6,
              horizontalScrollbarSize: 6,
              verticalSliderSize: 6,
            },
            readOnly: !!disabled,
          });

          editorRef.current = editor;

          editor.onDidChangeModelContent(() => {
            if (!isSettingValue.current && onChange) {
              onChange(editor.getValue());
            }
          });

          const model = editor.getModel();
          if (model) {
            const detectedLang = detectLanguage(value || '');
            if (detectedLang) {
              monaco.editor.setModelLanguage(model, detectedLang);
            }
          }
        });

        return () => {
          disposed = true;
          if (editorRef.current) {
            editorRef.current.dispose();
            editorRef.current = null;
          }
        };
      }, []);

      useEffect(() => {
        if (editorRef.current && value !== undefined) {
          const current = editorRef.current.getValue();
          if (current !== value) {
            isSettingValue.current = true;
            editorRef.current.setValue(value);
            isSettingValue.current = false;
          }
        }
      }, [value]);

      useEffect(() => {
        if (editorRef.current) {
          editorRef.current.updateOptions({ readOnly: !!disabled });
        }
      }, [disabled]);

      function detectLanguage(code) {
        if (/^\s*(import|from|def |class |if __name__)/.test(code)) return 'python';
        if (/^\s*(package |func |import "|\tgo )/.test(code)) return 'go';
        if (/^\s*(use |fn |let mut |impl |struct )/.test(code)) return 'rust';
        if (/^\s*(import|export|interface |type |const |=>)/.test(code) && /:\s*(string|number|boolean)/.test(code)) return 'typescript';
        if (/^\s*(public class|private |System\.out|import java)/.test(code)) return 'java';
        if (/^\s*(#include|std::|int main|cout|cin)/.test(code)) return 'cpp';
        if (/<\/?[a-z][\s\S]*>/i.test(code) && /className|onClick|useState/.test(code)) return 'javascript';
        return 'javascript';
      }

      return <div ref={containerRef} id="monaco-container" />;
    }

    /* ═══════════════════════════════════════════════
       LOGS PANEL (Agent Activity Log)
       ═══════════════════════════════════════════════ */

    const AGENT_STEPS = [
      { id: 'router',    icon: '🔍', label: 'Router',        detail: 'Analyzing code structure and routing to agents...' },
      { id: 'bughunter', icon: '🐛', label: 'BugHunter',     detail: 'Scanning for bugs, errors, and edge cases...' },
      { id: 'styleguard',icon: '✨', label: 'StyleGuard',    detail: 'Checking code style, naming, and conventions...' },
      { id: 'perfarch',  icon: '⚡', label: 'PerfArchitect', detail: 'Analyzing performance patterns and optimizations...' },
      { id: 'aggregate', icon: '📋', label: 'Aggregator',    detail: 'Compiling findings and generating report...' },
    ];

    function LogsPanel({ loading, completed }) {
      const [visibleLogs, setVisibleLogs] = useState([]);
      const intervalRef = useRef(null);

      useEffect(() => {
        if (loading && !completed) {
          setVisibleLogs([]);
          let step = 0;
          intervalRef.current = setInterval(() => {
            if (step < AGENT_STEPS.length) {
              setVisibleLogs(prev => {
                const updated = prev.map(l => ({ ...l, status: 'done' }));
                updated.push({ ...AGENT_STEPS[step], status: 'running' });
                return updated;
              });
              step++;
            } else {
              clearInterval(intervalRef.current);
            }
          }, 800);
        }

        if (completed) {
          clearInterval(intervalRef.current);
          setVisibleLogs(AGENT_STEPS.map(s => ({ ...s, status: 'done' })));
        }

        return () => clearInterval(intervalRef.current);
      }, [loading, completed]);

      if (!loading && !completed && visibleLogs.length === 0) {
        return (
          <div className="empty-state">
            <TerminalIcon size={40} />
            <p>Agent activity logs will appear here when you start a code review.</p>
          </div>
        );
      }

      return (
        <div>
          <div style={{ marginBottom: 12 }}>
            <span style={{ fontSize: 11, fontWeight: 600, color: '#8b949e', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
              Agent Pipeline
            </span>
          </div>
          {visibleLogs.map((log, idx) => (
            <div key={log.id} className={`log-entry ${log.status}`} style={{ animationDelay: `${idx * 50}ms` }}>
              <span style={{ fontSize: 18, lineHeight: 1, flexShrink: 0, marginTop: 1 }}>{log.icon}</span>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 2 }}>
                  <span style={{ fontSize: 13, fontWeight: 600, color: '#e6edf3' }}>{log.label}</span>
                  {log.status === 'running' && <SpinnerIcon size={12} />}
                  {log.status === 'done' && <span style={{ color: '#3fb950' }}><CheckIcon size={12} /></span>}
                </div>
                <p style={{ fontSize: 12, color: '#8b949e', margin: 0 }}>{log.detail}</p>
              </div>
              <span style={{ fontSize: 11, color: log.status === 'done' ? '#3fb950' : '#6e7681', flexShrink: 0, fontWeight: 500 }}>
                {log.status === 'done' ? 'Done' : 'Running'}
              </span>
            </div>
          ))}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       FINDING ITEM
       ═══════════════════════════════════════════════ */

    function FindingItem({ finding, index, decision, onApprove, onReject }) {
      const sev = (finding.severity || 'low').toLowerCase();
      const type = (finding.type || 'style').toLowerCase();

      return (
        <div className={`finding-card severity-${sev}`}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 12 }}>
            <div style={{ flex: 1, minWidth: 0 }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 6, marginBottom: 8, flexWrap: 'wrap' }}>
                <span className={`type-badge type-${type}`}>{finding.type || 'General'}</span>
                <span className={`sev-badge sev-${sev}`}>{finding.severity || 'low'}</span>
              </div>
              <p style={{ fontSize: 13, color: '#e6edf3', lineHeight: 1.5, margin: '0 0 10px 0' }}>
                {finding.message}
              </p>
              {finding.suggestion && (
                <div style={{ background: '#0d1117', border: '1px solid #21262d', borderRadius: 8, padding: '10px 12px' }}>
                  <p style={{ fontSize: 10, fontWeight: 700, color: '#8b949e', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 4px 0' }}>
                    Suggestion
                  </p>
                  <p style={{ fontSize: 12, color: '#7ee787', fontFamily: "'JetBrains Mono', monospace", margin: 0, lineHeight: 1.5 }}>
                    {finding.suggestion}
                  </p>
                </div>
              )}
            </div>
            <div className="toggle-group" style={{ flexShrink: 0 }}>
              <button
                className={`toggle-btn ${decision === 'approved' ? 'approved' : ''}`}
                onClick={() => onApprove(index)}
                title="Approve"
              >
                ✓
              </button>
              <button
                className={`toggle-btn ${decision === 'rejected' ? 'rejected' : ''}`}
                onClick={() => onReject(index)}
                title="Reject"
              >
                ✕
              </button>
            </div>
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       FINDINGS LIST
       ═══════════════════════════════════════════════ */

    function FindingsList({ findings, decisions, onApprove, onReject, onApproveAll, onRejectAll }) {
      if (!findings || findings.length === 0) {
        return (
          <div className="empty-state">
            <ListIcon size={40} />
            <p>No findings yet. Run a code review to see agent findings here.</p>
          </div>
        );
      }

      const approvedCount = Object.values(decisions).filter(d => d === 'approved').length;
      const rejectedCount = Object.values(decisions).filter(d => d === 'rejected').length;

      return (
        <div>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 14 }}>
            <div>
              <span style={{ fontSize: 11, fontWeight: 600, color: '#8b949e', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                {findings.length} findings
              </span>
              <span style={{ fontSize: 11, color: '#484f58', margin: '0 6px' }}>·</span>
              <span style={{ fontSize: 11, color: '#3fb950', fontWeight: 600 }}>{approvedCount} approved</span>
              <span style={{ fontSize: 11, color: '#484f58', margin: '0 6px' }}>·</span>
              <span style={{ fontSize: 11, color: '#f85149', fontWeight: 600 }}>{rejectedCount} rejected</span>
            </div>
            <div style={{ display: 'flex', gap: 6 }}>
              <button onClick={onApproveAll} className="btn-reset" style={{ padding: '3px 10px', fontSize: 11 }}>
                Approve All
              </button>
              <button onClick={onRejectAll} className="btn-reset" style={{ padding: '3px 10px', fontSize: 11 }}>
                Reject All
              </button>
            </div>
          </div>
          {findings.map((f, i) => (
            <FindingItem
              key={i}
              finding={f}
              index={i}
              decision={decisions[i]}
              onApprove={onApprove}
              onReject={onReject}
            />
          ))}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       DIFF VIEWER
       ═══════════════════════════════════════════════ */

    function DiffViewer({ diffData }) {
      if (!diffData) {
        return (
          <div className="empty-state">
            <DiffIcon size={40} />
            <p>The refactored code diff will appear here after you commit approved changes.</p>
          </div>
        );
      }

      const { original_code, final_code, diff } = diffData;

      const leftLines = [];
      const rightLines = [];
      let leftNum = 1;
      let rightNum = 1;

      (diff || []).forEach((change) => {
        const lines = change.value.replace(/\n$/, '').split('\n');
        lines.forEach((line) => {
          if (change.removed) {
            leftLines.push({ num: leftNum++, text: line, type: 'removed' });
            rightLines.push({ num: null, text: '', type: 'empty' });
          } else if (change.added) {
            leftLines.push({ num: null, text: '', type: 'empty' });
            rightLines.push({ num: rightNum++, text: line, type: 'added' });
          } else {
            leftLines.push({ num: leftNum++, text: line, type: 'unchanged' });
            rightLines.push({ num: rightNum++, text: line, type: 'unchanged' });
          }
        });
      });

      const stats = (diff || []).reduce((acc, change) => {
        const count = change.value.replace(/\n$/, '').split('\n').length;
        if (change.added) acc.added += count;
        else if (change.removed) acc.removed += count;
        return acc;
      }, { added: 0, removed: 0 });

      function renderPane(lines, title, dotColor) {
        return (
          <div className="diff-pane">
            <div className="diff-header">
              <span style={{ width: 7, height: 7, borderRadius: '50%', background: dotColor }} />
              <span style={{ fontSize: 11, fontWeight: 600, color: '#8b949e', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                {title}
              </span>
            </div>
            <div style={{ flex: 1, overflowY: 'auto' }}>
              {lines.map((line, i) => (
                <div key={i} className={`diff-line ${line.type}`}>
                  <span className="diff-num" style={{ color: line.type === 'removed' ? '#f8514966' : line.type === 'added' ? '#3fb95066' : '#484f58' }}>
                    {line.num || ''}
                  </span>
                  <span className="diff-prefix" style={{ color: line.type === 'removed' ? '#f85149' : line.type === 'added' ? '#3fb950' : '#30363d' }}>
                    {line.type === 'removed' ? '−' : line.type === 'added' ? '+' : ' '}
                  </span>
                  <span className="diff-text" style={{ color: line.type === 'removed' ? '#ffa198' : line.type === 'added' ? '#7ee787' : '#e6edf3' }}>
                    {line.text}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      }

      return (
        <div style={{ display: 'flex', flexDirection: 'column', height: '100%' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12, marginBottom: 12 }}>
            <span className="stat-chip" style={{ color: '#3fb950' }}>+{stats.added}</span>
            <span className="stat-chip" style={{ color: '#f85149' }}>−{stats.removed}</span>
            <span style={{ fontSize: 12, color: '#484f58' }}>lines changed</span>
          </div>
          <div style={{ display: 'flex', flex: 1, border: '1px solid #21262d', borderRadius: 10, overflow: 'hidden', minHeight: 0 }}>
            {renderPane(leftLines, 'Original', '#f85149')}
            <div style={{ width: 1, background: '#21262d' }} />
            {renderPane(rightLines, 'Refactored', '#3fb950')}
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       APP (Main Container)
       ═══════════════════════════════════════════════ */

    function Sidebar({ sessions, activeSessionId, onSelectSession, onCreateSession }) {
      return (
        <div style={{ borderRight: '1px solid #21262d', display: 'flex', flexDirection: 'column', background: '#0d1117' }}>
          <div style={{ padding: '16px', borderBottom: '1px solid #21262d' }}>
            <button onClick={onCreateSession} className="btn-primary" style={{ width: '100%', justifyContent: 'center' }}>
              + New Session
            </button>
          </div>
          <div style={{ flex: 1, overflowY: 'auto' }}>
            {sessions.map(session => (
              <div 
                key={session.id} 
                onClick={() => onSelectSession(session.id)}
                style={{ 
                  padding: '12px 16px', cursor: 'pointer', borderBottom: '1px solid #21262d',
                  background: activeSessionId === session.id ? '#161b22' : 'transparent',
                  borderLeft: activeSessionId === session.id ? '3px solid #58a6ff' : '3px solid transparent'
                }}
              >
                <div style={{ fontSize: '13px', fontWeight: '600', color: '#e6edf3', marginBottom: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                  {session.title}
                </div>
                <div style={{ fontSize: '11px', color: '#8b949e' }}>
                  {new Date(session.updatedAt).toLocaleDateString()}
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    }

    function App() {
      const [inputCode, setInputCode] = useState('');
      const [loading, setLoading] = useState(false);
      const [status, setStatus] = useState('idle');
      const [logs, setLogs] = useState([]);
      const [findings, setFindings] = useState([]);
      const [decisions, setDecisions] = useState({});
      const [threadId, setThreadId] = useState(null);
      const [finalCode, setFinalCode] = useState('');
      const [diffData, setDiffData] = useState(null);
      const [error, setError] = useState(null);
      const [activeTab, setActiveTab] = useState('logs');
      const [sessions, setSessions] = useState([]);
      const [activeSessionId, setActiveSessionId] = useState(null);

      useEffect(() => {
        fetch('/sessions').then(r => r.json()).then(data => {
          setSessions(data);
          if (data.length > 0 && !activeSessionId) setActiveSessionId(data[data.length-1].id);
        }).catch(err => console.error(err));
      }, []);

      const handleSelectSession = useCallback((id) => {
        setActiveSessionId(id);
        fetch(`/sessions/${id}`)
          .then(r => {
             if (!r.ok) throw new Error("Session not found");
             return r.json();
          })
          .then(data => {
            setThreadId(id);
            
            // Sync editor with session codebase
            const contextHistory = data.context || [];
            const lastCodeEntry = contextHistory.filter(c => c.type === 'code').pop();
            
            setInputCode(lastCodeEntry ? lastCodeEntry.content : '');
            setFindings([]);
            setStatus('idle');
            setLogs([]);
            setDiffData(null);
            setFinalCode('');
          })
          .catch(err => {
             console.error("Session switch error:", err);
             setError("Failed to load session context");
          });
      }, []);

      const handleCreateSession = useCallback(() => {
        fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) })
          .then(r => r.json())
          .then(newSession => {
             setSessions(prev => [...prev, newSession]);
             setActiveSessionId(newSession.id);
             setThreadId(newSession.id);
             setInputCode('');
             setFindings([]);
             setStatus('idle');
          });
      }, []);

      const handleApproveItem = useCallback((index) => {
        setDecisions(prev => ({
          ...prev,
          [index]: prev[index] === 'approved' ? undefined : 'approved'
        }));
      }, []);

      const handleRejectItem = useCallback((index) => {
        setDecisions(prev => ({
          ...prev,
          [index]: prev[index] === 'rejected' ? undefined : 'rejected'
        }));
      }, []);

      const handleApproveAll = useCallback(() => {
        setDecisions(prev => {
          const next = {};
          findings.forEach((_, i) => { next[i] = 'approved'; });
          return next;
        });
      }, [findings]);

      const handleRejectAll = useCallback(() => {
        setDecisions(prev => {
          const next = {};
          findings.forEach((_, i) => { next[i] = 'rejected'; });
          return next;
        });
      }, [findings]);

      async function handleAnalyze() {
        if (!inputCode.trim()) return;
        setStatus('loading');
        setLoading(true);
        setError(null);
        setFindings([]);
        setDecisions({});
        setDiffData(null);
        setFinalCode('');
        setActiveTab('logs');

        try {
          let currentSessionId = activeSessionId;
          
          if (!currentSessionId) {
             const res = await fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) });
             const newSession = await res.json();
             setSessions(prev => [...prev, newSession]);
             currentSessionId = newSession.id;
             setActiveSessionId(currentSessionId);
             setThreadId(currentSessionId);
          }

          const res = await fetch(`/sessions/${currentSessionId}/input`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'code', content: inputCode, input_code: inputCode }),
          });
          const data = await res.json();

          if (data.error) throw new Error(data.error);

          const report = data.aggregated_report || data.findings || [];
          setFindings(report);

          const initialDecisions = {};
          report.forEach((_, i) => { initialDecisions[i] = 'approved'; });
          setDecisions(initialDecisions);

          setLoading(false);
          setStatus('pending');
          setActiveTab('findings');
        } catch (err) {
          setError(err.message);
          setLoading(false);
          setStatus('error');
        }
      }

      async function handleCommit() {
        const approved = findings.filter((_, i) => decisions[i] === 'approved');
        if (approved.length === 0) return;

        setStatus('approving');
        setError(null);

        try {
          const res = await fetch('/review/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              thread_id: threadId,
              approved_suggestions: approved,
            }),
          });
          const data = await res.json();

          if (data.error) throw new Error(data.error);

          setFinalCode(data.final_code || data.diffData?.final_code || '');
          setDiffData(data.diffData || null);
          setStatus('completed');
          setActiveTab('results');
        } catch (err) {
          setError(err.message);
          setStatus('error');
        }
      }

      function handleReset() {
        setInputCode('');
        setLoading(false);
        setStatus('idle');
        setLogs([]);
        setFindings([]);
        setDecisions({});
        setThreadId(null);
        setFinalCode('');
        setDiffData(null);
        setError(null);
        setActiveTab('logs');
      }

      const approvedCount = Object.values(decisions).filter(d => d === 'approved').length;
      const canCommit = status === 'pending' && approvedCount > 0;
      const canAnalyze = (status === 'idle' || status === 'error') && inputCode.trim().length > 0;
      const isAnalyzeDisabled = !canAnalyze || status === 'loading';

      const findingsTabLabel = findings.length > 0 ? `Findings (${findings.length})` : 'Findings';

      useEffect(() => {
        function handleKeyDown(e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            if (canAnalyze) handleAnalyze();
          }
        }
        window.addEventListener('keydown', handleKeyDown);
        return () => window.removeEventListener('keydown', handleKeyDown);
      }, [canAnalyze, inputCode]);

      return (
        <div className="app-shell">
          {/* ── HEADER BAR ── */}
          <div className="header-bar">
            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              <div style={{
                width: 28, height: 28, borderRadius: 7,
                background: 'linear-gradient(135deg, #6366f1, #8b5cf6)',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
                boxShadow: '0 0 12px rgba(99, 102, 241, 0.3)',
              }}>
                <ShieldIcon size={16} />
              </div>
              <span style={{ fontSize: 14, fontWeight: 700, letterSpacing: '-0.01em' }}>
                Sentinel-Graph
              </span>
            </div>
            <div style={{ flex: 1 }} />
            <StatusBadge status={status} />
            {error && (
              <div style={{
                display: 'flex', alignItems: 'center', gap: 6,
                background: 'rgba(248,81,73,0.1)', padding: '3px 10px',
                borderRadius: 6, fontSize: 11, color: '#f85149', fontWeight: 500,
                maxWidth: 300, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap'
              }}>
                ⚠ {error}
              </div>
            )}
          </div>

          {/* ── MAIN AREA ── */}
          <div className="main-area">
            <Sidebar 
              sessions={sessions} 
              activeSessionId={activeSessionId} 
              onSelectSession={handleSelectSession} 
              onCreateSession={handleCreateSession} 
            />
            {/* LEFT: Code Editor */}
            <div className="editor-pane">
              <div className="pane-header">
                <svg width={14} height={14} viewBox="0 0 24 24" fill="none" stroke="#8b949e" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
                  <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                </svg>
                <span>Editor</span>
                <div style={{ flex: 1 }} />
                <span style={{ fontSize: 10, color: '#484f58', fontFamily: "'JetBrains Mono', monospace" }}>
                  {inputCode.split('\n').length} lines
                </span>
              </div>
              <Editor
                value={inputCode}
                onChange={setInputCode}
                disabled={status === 'loading' || status === 'approving'}
              />
            </div>

            {/* RIGHT: Tabbed Panel */}
            <div className="right-pane">
              <div className="tab-strip">
                <button
                  className={`tab-btn ${activeTab === 'logs' ? 'active' : ''}`}
                  onClick={() => setActiveTab('logs')}
                >
                  <TerminalIcon size={13} />
                  Logs
                </button>
                <button
                  className={`tab-btn ${activeTab === 'findings' ? 'active' : ''}`}
                  onClick={() => setActiveTab('findings')}
                >
                  <ListIcon size={13} />
                  {findingsTabLabel}
                </button>
                <button
                  className={`tab-btn ${activeTab === 'results' ? 'active' : ''}`}
                  onClick={() => setActiveTab('results')}
                >
                  <DiffIcon size={13} />
                  Results
                </button>
              </div>
              <div className="tab-content">
                {activeTab === 'logs' && (
                  <LogsPanel
                    loading={status === 'loading'}
                    completed={status === 'pending' || status === 'completed' || status === 'approving'}
                  />
                )}
                {activeTab === 'findings' && (
                  <FindingsList
                    findings={findings}
                    decisions={decisions}
                    onApprove={handleApproveItem}
                    onReject={handleRejectItem}
                    onApproveAll={handleApproveAll}
                    onRejectAll={handleRejectAll}
                  />
                )}
                {activeTab === 'results' && (
                  <DiffViewer diffData={diffData} />
                )}
              </div>
            </div>
          </div>

          {/* ── ACTION BAR ── */}
          <div className="action-bar">
            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              {(status === 'pending' || status === 'completed') && (
                <button className="btn-reset" onClick={handleReset}>
                  <RefreshIcon size={12} />
                  New Review
                </button>
              )}
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              {status === 'pending' && (
                <span style={{ fontSize: 12, color: '#8b949e' }}>
                  <span style={{ color: '#3fb950', fontWeight: 600 }}>{approvedCount}</span> approved
                </span>
              )}
              <button
                className="btn-primary btn-analyze"
                onClick={handleAnalyze}
                disabled={isAnalyzeDisabled}
                style={{ display: status === 'pending' || status === 'approving' || status === 'completed' ? 'none' : 'inline-flex' }}
                title="Ctrl+Enter"
              >
                {status === 'loading' ? (
                  <><SpinnerIcon size={14} /> Analyzing...</>
                ) : (
                  <><ZapIcon size={14} /> Analyze Code</>
                )}
              </button>
              <button
                className="btn-primary btn-commit"
                onClick={handleCommit}
                disabled={!canCommit}
                style={{ display: status === 'pending' || status === 'approving' ? 'inline-flex' : 'none' }}
              >
                {status === 'approving' ? (
                  <><SpinnerIcon size={14} /> Committing...</>
                ) : (
                  <><CheckIcon size={14} /> Commit Changes</>
                )}
              </button>
            </div>
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       MOUNT
       ═══════════════════════════════════════════════ */

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
