<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sentinel-Graph — AI Code Review</title>
  <meta name="description" content="AI-powered multi-agent code review system with human-in-the-loop approval workflow">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
        },
      },
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body, #root { height: 100%; margin: 0; overflow: hidden; }
    body { font-family: 'Inter', system-ui, sans-serif; transition: background-color 0.2s, color 0.2s; }

    .app-shell {
      display: grid;
      grid-template-rows: 48px 1fr 56px;
      height: 100vh;
    }

    .header-bar {
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 12px;
      z-index: 50;
    }

    .main-area {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    .resize-handle {
      position: relative;
      flex: 0 0 4px;
      cursor: col-resize;
      background: rgba(74, 222, 128, 0.15);
      transition: background 0.15s ease;
      z-index: 10;
    }
    .resize-handle:hover, .resize-handle[data-resize-handle-active] {
      background: #4ade80;
    }
    .resize-indicator {
      position: absolute;
      top: 0; left: -4px; right: -4px; bottom: 0;
    }

    .editor-pane {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      height: 100%;
      min-height: 0;
    }

    .right-pane {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      height: 100%;
      min-height: 0;
    }

    .action-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      z-index: 50;
    }

    .tab-strip {
      display: flex;
      padding: 0 4px;
      flex-shrink: 0;
    }

    .tab-btn {
      padding: 8px 16px;
      font-size: 12px;
      font-weight: 500;
      color: #8b949e;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      transition: all 0.15s ease;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }
    .tab-btn:hover { color: #e6edf3; }
    .tab-btn.active {
      color: #e6edf3;
      border-bottom-color: #4ade80;
    }

    .tab-content {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
    }

    .tab-content::-webkit-scrollbar { width: 6px; }
    .tab-content::-webkit-scrollbar-track { background: transparent; }
    .tab-content::-webkit-scrollbar-thumb { background: rgba(74, 222, 128, 0.2); border-radius: 3px; }
    .tab-content::-webkit-scrollbar-thumb:hover { background: rgba(74, 222, 128, 0.35); }

    .pane-header {
      display: flex;
      align-items: center;
      padding: 0 12px;
      height: 36px;
      flex-shrink: 0;
      gap: 8px;
    }
    .pane-header span {
      font-size: 11px;
      font-weight: 600;
      color: #8b949e;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    #monaco-container {
      flex: 1;
      min-height: 0;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.03em;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: all 0.15s ease;
      color: #fff;
    }
    .btn-primary:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .btn-analyze {
      background: linear-gradient(135deg, #22c55e, #16a34a);
    }
    .btn-analyze:not(:disabled):hover {
      background: linear-gradient(135deg, #4ade80, #22c55e);
      box-shadow: 0 0 20px rgba(34, 197, 94, 0.3);
    }

    .btn-commit {
      background: linear-gradient(135deg, #059669, #047857);
    }
    .btn-commit:not(:disabled):hover {
      background: linear-gradient(135deg, #10b981, #059669);
      box-shadow: 0 0 20px rgba(5, 150, 105, 0.3);
    }

    .btn-reset {
      background: transparent;
      border: 1px solid #1e3a2f;
      color: #8b949e;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .btn-reset:hover {
      border-color: #4ade80;
      color: #e6edf3;
    }

    .log-entry {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 8px 12px;
      border-radius: 8px;
      margin-bottom: 4px;
      font-size: 13px;
      animation: logFadeIn 0.3s ease-out forwards;
      opacity: 0;
    }
    .log-entry.done { background: rgba(74, 222, 128, 0.06); }
    .log-entry.running { background: rgba(34, 197, 94, 0.08); }
    .log-entry.waiting { background: transparent; }

    @keyframes logFadeIn {
      from { opacity: 0; transform: translateX(-8px); }
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    .pulse-dot { animation: pulse-dot 1.2s ease-in-out infinite; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spin-icon { animation: spin 1s linear infinite; }

    .finding-card {
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 10px;
      transition: all 0.2s ease;
    }
    .finding-card:hover {
      border-color: #1e3a2f;
      box-shadow: 0 2px 16px rgba(74, 222, 128, 0.08);
    }
    .finding-card.severity-high { border-left: 3px solid #f85149; }
    .finding-card.severity-medium { border-left: 3px solid #d29922; }
    .finding-card.severity-low { border-left: 3px solid #4ade80; }

    .sev-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .sev-high { background: rgba(248,81,73,0.15); color: #f85149; }
    .sev-medium { background: rgba(210,153,34,0.15); color: #d29922; }
    .sev-low { background: rgba(74,222,128,0.15); color: #4ade80; }

    .type-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .type-bug { background: rgba(248,81,73,0.12); color: #ff7b72; }
    .type-style { background: rgba(74,222,128,0.12); color: #86efac; }
    .type-performance { background: rgba(210,153,34,0.12); color: #e3b341; }

    .toggle-group {
      display: inline-flex;
      border-radius: 6px;
      overflow: hidden;
      border: 1px solid #1e3a2f;
    }
    .toggle-btn {
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
      background: transparent;
      color: #8b949e;
      border: none;
    }
    .toggle-btn:first-child { border-right: 1px solid #1e3a2f; }
    .toggle-btn.approved {
      background: rgba(74, 222, 128, 0.15);
      color: #4ade80;
    }
    .toggle-btn.rejected {
      background: rgba(248, 81, 73, 0.15);
      color: #f85149;
    }

    .diff-pane {
      display: flex;
      flex: 1;
      min-width: 0;
      flex-direction: column;
    }
    .diff-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      flex-shrink: 0;
    }
    .diff-line {
      display: flex;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      line-height: 20px;
      transition: background 0.1s;
    }
    .diff-line:hover { background: rgba(255,255,255,0.02); }
    .diff-line.removed { background: rgba(248,81,73,0.08); }
    .diff-line.added { background: rgba(74,222,128,0.08); }
    .diff-line.empty { background: rgba(255,255,255,0.01); }
    .diff-num {
      flex-shrink: 0;
      width: 48px;
      text-align: right;
      padding-right: 8px;
      user-select: none;
      color: #484f58;
    }
    .diff-prefix {
      flex-shrink: 0;
      width: 20px;
      text-align: center;
      user-select: none;
    }
    .diff-text {
      flex: 1;
      padding-right: 12px;
      white-space: pre;
    }

    .stat-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: #484f58;
      gap: 12px;
      text-align: center;
      padding: 40px;
    }
    .empty-state svg { opacity: 0.3; }
    .empty-state p { font-size: 13px; max-width: 280px; line-height: 1.5; }
  </style>
</head>
<body className="bg-white text-black dark:bg-[#0d1117] dark:text-[#e6edf3] transition-colors duration-200">

  <div id="root"></div>

  <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://unpkg.com/react-resizable-panels@2.1.4/dist/index.umd.js"></script>

  <script>
    window.require = { paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' } };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>

  <script type="text/babel">
    const { useState, useEffect, useRef, useCallback } = React;
    const PanelGroup = window.ReactResizablePanels ? window.ReactResizablePanels.PanelGroup : null;
    const Panel = window.ReactResizablePanels ? window.ReactResizablePanels.Panel : null;
    const PanelResizeHandle = window.ReactResizablePanels ? window.ReactResizablePanels.PanelResizeHandle : null;

    if (!PanelGroup) {
      console.warn("react-resizable-panels not loaded. Using fallback layout.");
    }

    class ErrorBoundary extends React.Component {
      constructor(props) {
        super(props);
        this.state = { hasError: false };
      }
      static getDerivedStateFromError(error) {
        return { hasError: true };
      }
      componentDidCatch(error, errorInfo) {
        console.error("UI Crash detected:", error, errorInfo);
      }
      render() {
        if (this.state.hasError) {
          return <div style={{ padding: 20, color: '#f85149', fontFamily: 'monospace', display: 'flex', alignItems: 'center', gap: 8 }}><AlertTriangleIcon size={16} /> UI Crash Detected. Check console for details.</div>;
        }
        return this.props.children;
      }
    }

    function ResizeHandle({ vertical }) {
      return (
        <PanelResizeHandle className="resize-handle" style={{ cursor: vertical ? 'row-resize' : 'col-resize' }}>
          <div className="resize-indicator" />
        </PanelResizeHandle>
      );
    }

    /* ═══════════════════════════════════════════════
       ICONS (inline SVG helpers)
       ═══════════════════════════════════════════════ */

    function ShieldIcon({ size = 20 }) {
