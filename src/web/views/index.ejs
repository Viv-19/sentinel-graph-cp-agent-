          ))}
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       DIFF VIEWER
       ═══════════════════════════════════════════════ */

    function DiffViewer({ diffData }) {
      if (!diffData) {
        return (
          <div className="empty-state">
            <DiffIcon size={40} />
            <p>The refactored code diff will appear here after you commit approved changes.</p>
          </div>
        );
      }

      const { original_code, final_code, diff } = diffData;

      const leftLines = [];
      const rightLines = [];
      let leftNum = 1;
      let rightNum = 1;

      (diff || []).forEach((change) => {
        const lines = change.value.replace(/\n$/, '').split('\n');
        lines.forEach((line) => {
          if (change.removed) {
            leftLines.push({ num: leftNum++, text: line, type: 'removed' });
            rightLines.push({ num: null, text: '', type: 'empty' });
          } else if (change.added) {
            leftLines.push({ num: null, text: '', type: 'empty' });
            rightLines.push({ num: rightNum++, text: line, type: 'added' });
          } else {
            leftLines.push({ num: leftNum++, text: line, type: 'unchanged' });
            rightLines.push({ num: rightNum++, text: line, type: 'unchanged' });
          }
        });
      });

      const stats = (diff || []).reduce((acc, change) => {
        const count = change.value.replace(/\n$/, '').split('\n').length;
        if (change.added) acc.added += count;
        else if (change.removed) acc.removed += count;
        return acc;
      }, { added: 0, removed: 0 });

      function renderPane(lines, title, dotColor) {
        return (
          <div className="diff-pane">
            <div className="diff-header bg-gray-50 dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d]">
              <span style={{ width: 7, height: 7, borderRadius: '50%', background: dotColor }} />
              <span className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: 11, fontWeight: 600, textTransform: 'uppercase', letterSpacing: '0.05em' }}>
                {title}
              </span>
            </div>
            <div style={{ flex: 1, overflowY: 'auto' }}>
              {lines.map((line, i) => (
                <div key={i} className={`diff-line ${line.type}`}>
                  <span className="diff-num" style={{ color: line.type === 'removed' ? '#f8514966' : line.type === 'added' ? '#3fb95066' : '#484f58' }}>
                    {line.num || ''}
                  </span>
                  <span className="diff-prefix" style={{ color: line.type === 'removed' ? '#f85149' : line.type === 'added' ? '#3fb950' : '#30363d' }}>
                    {line.type === 'removed' ? '−' : line.type === 'added' ? '+' : ' '}
                  </span>
                  <span className="diff-text" style={{ color: line.type === 'removed' ? '#ffa198' : line.type === 'added' ? '#7ee787' : '#e6edf3' }}>
                    {line.text}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      }

      return (
        <div style={{ display: 'flex', flexDirection: 'column', height: '100%' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12, marginBottom: 12 }}>
            <span className="stat-chip" style={{ color: '#3fb950' }}>+{stats.added}</span>
            <span className="stat-chip" style={{ color: '#f85149' }}>−{stats.removed}</span>
            <span style={{ fontSize: 12, color: '#484f58' }}>lines changed</span>
          </div>
          <div style={{ display: 'flex', flex: 1, border: '1px solid #21262d', borderRadius: 10, overflow: 'hidden', minHeight: 0 }}>
            {renderPane(leftLines, 'Original', '#f85149')}
            <div style={{ width: 1, background: '#21262d' }} />
            {renderPane(rightLines, 'Refactored', '#3fb950')}
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       APP (Main Container)
       ═══════════════════════════════════════════════ */

    function Sidebar({ sessions, activeSessionId, onSelectSession, onCreateSession, isOpen }) {
      const sortedSessions = [...sessions].sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));

      return (
        <div className="bg-white dark:bg-[#0d1117] border-r border-gray-200 dark:border-[#21262d] transition-colors duration-200" style={{ display: 'flex', flexDirection: 'column', height: '100%', width: '100%', transition: 'width 0.2s ease, background-color 0.2s, border-color 0.2s' }}>
          <div className="border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200" style={{ padding: '16px', textAlign: 'center' }}>
            <button onClick={onCreateSession} className="bg-gray-100 text-gray-900 dark:bg-[#0d1117] dark:text-[#e6edf3] hover:bg-gray-200 dark:hover:bg-[#161b22] transition-colors duration-200" style={{ width: '100%', justifyContent: 'center', padding: '6px 16px', borderRadius: '8px', fontSize: '13px', fontWeight: '600', border: 'none', cursor: 'pointer', display: 'flex', alignItems: 'center' }}>
              {isOpen ? '+ New Session' : '+'}
            </button>
          </div>
          <div style={{ flex: 1, overflowY: 'auto' }}>
            {sortedSessions.map(session => (
              <div 
                key={session.id} 
                onClick={() => onSelectSession(session.id)}
                title={session.title}
                className={activeSessionId === session.id ? 'bg-gray-100 dark:bg-[#161b22]' : 'hover:bg-gray-50 dark:hover:bg-[#161b22] transition-colors duration-200'}
                style={{ 
                  padding: isOpen ? '12px 16px' : '12px 0', cursor: 'pointer', borderBottom: '1px solid var(--border-color)',
                  borderLeft: activeSessionId === session.id ? '3px solid #58a6ff' : '3px solid transparent',
                  textAlign: isOpen ? 'left' : 'center'
                }}
              >
                {isOpen ? (
                  <>
                    <div className="text-gray-700 dark:text-[#e6edf3]" style={{ fontSize: '13px', fontWeight: '600', marginBottom: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                      {session.title}
                    </div>
                    <div className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: '11px' }}>
                      {new Date(session.updatedAt).toLocaleDateString()}
                    </div>
                  </>
                ) : (
                  <div className="text-gray-700 dark:text-[#e6edf3]" style={{ fontSize: '12px', fontWeight: 'bold' }}>
                    {session.title.substring(0, 2).toUpperCase()}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      );
    }

    function App() {
      const [inputCode, setInputCode] = useState('');
      const [loading, setLoading] = useState(false);
      const [status, setStatus] = useState('idle');
      const [logs, setLogs] = useState([]);
      const [findings, setFindings] = useState([]);
      const [decisions, setDecisions] = useState({});
      const [threadId, setThreadId] = useState(null);
      const [finalCode, setFinalCode] = useState('');
      const [diffData, setDiffData] = useState(null);
      const [error, setError] = useState(null);
      const [activeTab, setActiveTab] = useState('logs');
      const [sessions, setSessions] = useState([]);
      const [activeSessionId, setActiveSessionId] = useState(null);
      const [problemDescription, setProblemDescription] = useState('');
      const [problemAnalysis, setProblemAnalysis] = useState(null);
      const [constraintInsights, setConstraintInsights] = useState(null);
      const [expectedTC, setExpectedTC] = useState('');
      const [expectedSC, setExpectedSC] = useState('');
      const [complexityReasoning, setComplexityReasoning] = useState('');
      const [detectedPattern, setDetectedPattern] = useState('');
      const [patternConfidence, setPatternConfidence] = useState(0);
      const [strategyPlan, setStrategyPlan] = useState(null);
      const [testCaseValidation, setTestCaseValidation] = useState(null);
      const [analysisStatus, setAnalysisStatus] = useState('IDLE');

      const [analyzingProblem, setAnalyzingProblem] = useState(false);
      const [problemAnalysisDone, setProblemAnalysisDone] = useState(false);
      const [sidebarOpen, setSidebarOpen] = useState(true);
      const [theme, setTheme] = useState(() => {
        return localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      });

      useEffect(() => {
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
        localStorage.setItem("theme", theme);
      }, [theme]);

      function toggleTheme() {
        setTheme(prev => prev === "dark" ? "light" : "dark");
      }

      useEffect(() => {
        fetch('/sessions').then(r => r.json()).then(data => {
          setSessions(data);
          if (data.length > 0 && !activeSessionId) setActiveSessionId(data[data.length-1].id);
        }).catch(err => console.error(err));
      }, []);

      const handleSelectSession = useCallback((id) => {
        setActiveSessionId(id);
        fetch(`/sessions/${id}`)
          .then(r => {
             if (!r.ok) throw new Error("Session not found");
             return r.json();
          })
          .then(data => {
            setThreadId(id);
            
            // Sync editor with session codebase
            const contextHistory = data.context || [];
            const lastCodeEntry = contextHistory.filter(c => c.type === 'code').pop();
            
            setInputCode(lastCodeEntry ? lastCodeEntry.content : '');
            setProblemDescription(data.problem_description || '');
            setProblemAnalysis(data.problem_analysis || null);
            setConstraintInsights(data.constraint_insights || null);
            setExpectedTC(data.expected_time_complexity || '');
            setExpectedSC(data.expected_space_complexity || '');
            setComplexityReasoning(data.complexity_reasoning || '');
            setDetectedPattern(data.detected_pattern || '');
            setPatternConfidence(data.pattern_confidence || 0);
            setStrategyPlan(data.strategy_plan || null);
            setTestCaseValidation(data.test_case_validation || null);
            setAnalysisStatus(data.analysis_status || 'IDLE');
            setFindings([]);
            setStatus('idle');
            setLogs([]);
            setDiffData(null);
            setFinalCode('');
          })
          .catch(err => {
             console.error("Session switch error:", err);
             setError("Failed to load session context");
          });
      }, []);

      const handleCreateSession = useCallback(() => {
        fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) })
          .then(r => r.json())
          .then(newSession => {
             setSessions(prev => [...prev, newSession]);
             setActiveSessionId(newSession.id);
             setThreadId(newSession.id);
             setInputCode('');
             setProblemDescription('');
             setProblemAnalysis(null);
             setConstraintInsights(null);
             setExpectedTC('');
             setExpectedSC('');
             setComplexityReasoning('');
             setDetectedPattern('');
             setPatternConfidence(0);
             setStrategyPlan(null);
             setTestCaseValidation(null);
             setAnalysisStatus('IDLE');
             setFindings([]);
             setDecisions({});
             setStatus('idle');
             setLogs([]);
             setDiffData(null);
             setFinalCode('');
             setError(null);
          });
      }, []);



      const handleAnalyzeProblem = useCallback(async () => {
        if (!activeSessionId || !problemDescription.trim()) return;
        setAnalyzingProblem(true);
        setProblemAnalysisDone(false);
        setError(null);
        try {
          const res = await fetch(`/sessions/${activeSessionId}/problem/analyze`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ problem_description: problemDescription })
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);
          if (data.problem_analysis) {
            setProblemAnalysis(data.problem_analysis);
            setConstraintInsights(data.constraint_insights);
            setExpectedTC(data.expected_time_complexity);
            setExpectedSC(data.expected_space_complexity);
            setComplexityReasoning(data.complexity_reasoning);
            setDetectedPattern(data.detected_pattern);
            setPatternConfidence(data.pattern_confidence);
            setStrategyPlan(data.strategy_plan);
            setTestCaseValidation(data.test_case_validation);
          }
          if (data.status) {
             setAnalysisStatus(data.status);
          }
          setProblemAnalysisDone(true);
        } catch (err) {
          setError('Problem analysis failed: ' + err.message);
        } finally {
          setAnalyzingProblem(false);
        }
      }, [activeSessionId, problemDescription]);

      const handleDecision = useCallback(async (decision) => {
        if (!activeSessionId) return;
        setAnalysisStatus('LOADING_DECISION');
        try {
          const res = await fetch(`/sessions/${activeSessionId}/problem/decision`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ decision })
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);
          if (data.status) {
             setAnalysisStatus(data.status);
          }
          if (data.input_code) {
             setInputCode(data.input_code);
          }
        } catch (err) {
          alert('Error submitting decision: ' + err.message);
          setAnalysisStatus('PENDING_DECISION');
        }
      }, [activeSessionId]);

      const handleApproveItem = useCallback((index) => {
        setDecisions(prev => ({
          ...prev,
          [index]: prev[index] === 'approved' ? undefined : 'approved'
        }));
      }, []);

      const handleRejectItem = useCallback((index) => {
        setDecisions(prev => ({
          ...prev,
          [index]: prev[index] === 'rejected' ? undefined : 'rejected'
        }));
      }, []);

      const handleApproveAll = useCallback(() => {
        setDecisions(prev => {
          const next = {};
          findings.forEach((_, i) => { next[i] = 'approved'; });
          return next;
        });
      }, [findings]);

      const handleRejectAll = useCallback(() => {
        setDecisions(prev => {
          const next = {};
          findings.forEach((_, i) => { next[i] = 'rejected'; });
          return next;
        });
      }, [findings]);

      async function handleAnalyze() {
        if (!inputCode.trim()) return;
        setStatus('loading');
        setLoading(true);
        setError(null);
        setFindings([]);
        setDecisions({});
        setDiffData(null);
        setFinalCode('');
        setActiveTab('logs');

        try {
          let currentSessionId = activeSessionId;
          
          if (!currentSessionId) {
             const res = await fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'New Problem' }) });
             const newSession = await res.json();
             setSessions(prev => [...prev, newSession]);
             currentSessionId = newSession.id;
             setActiveSessionId(currentSessionId);
             setThreadId(currentSessionId);
          }

          const res = await fetch(`/sessions/${currentSessionId}/input`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'code', content: inputCode, input_code: inputCode }),
          });
          const data = await res.json();

          if (data.error) throw new Error(data.error);

          // Store the review thread_id from Python for approval
          if (data.thread_id) {
            setThreadId(data.thread_id);
          }

          const report = data.aggregated_report || data.findings || [];
          setFindings(report);

          const initialDecisions = {};
          report.forEach((_, i) => { initialDecisions[i] = 'approved'; });
          setDecisions(initialDecisions);

          setLoading(false);
          setStatus('pending');
          setActiveTab('findings');
        } catch (err) {
          setError(err.message);
          setLoading(false);
          setStatus('error');
        }
      }

      async function handleCommit() {
        const approved = findings.filter((_, i) => decisions[i] === 'approved');
        if (approved.length === 0) return;

        setStatus('approving');
        setError(null);

        try {
          // Use session-aware approval endpoint which uses stored review_thread_id
          const endpoint = activeSessionId 
            ? `/sessions/${activeSessionId}/review/approve`
            : '/review/approve';
          
          const body = activeSessionId
            ? { approved_suggestions: approved }
            : { thread_id: threadId, approved_suggestions: approved };

          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          const data = await res.json();

          if (data.error) throw new Error(data.error);

          setFinalCode(data.final_code || data.diffData?.final_code || '');
          setDiffData(data.diffData || null);
          setStatus('completed');
          setActiveTab('results');
        } catch (err) {
          setError(err.message);
          setStatus('error');
        }
      }

      function handleReset() {
        setInputCode('');
        setLoading(false);
        setStatus('idle');
        setLogs([]);
        setFindings([]);
        setDecisions({});
        setThreadId(null);
        setFinalCode('');
        setDiffData(null);
        setError(null);
        setActiveTab('logs');
        setProblemDescription('');
        setProblemAnalysis(null);
        setConstraintInsights(null);
        setExpectedTC('');
        setExpectedSC('');
        setComplexityReasoning('');
        setDetectedPattern('');
        setPatternConfidence(0);
        setStrategyPlan(null);
        setTestCaseValidation(null);
        setAnalysisStatus('IDLE');
      }

      // Re-run review on updated code without resetting analysis state
      async function handleImproveCode() {
        if (!inputCode.trim() || !activeSessionId) return;
        setStatus('loading');
        setLoading(true);
        setError(null);
        setFindings([]);
        setDecisions({});
        setDiffData(null);
        setFinalCode('');
        setActiveTab('logs');

        try {
          const res = await fetch(`/sessions/${activeSessionId}/input`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'code', content: inputCode, input_code: inputCode }),
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error);

          if (data.thread_id) setThreadId(data.thread_id);

          const report = data.aggregated_report || data.findings || [];
          setFindings(report);
          const initialDecisions = {};
          report.forEach((_, i) => { initialDecisions[i] = 'approved'; });
          setDecisions(initialDecisions);

          setLoading(false);
          setStatus('pending');
          setActiveTab('findings');
        } catch (err) {
          setError(err.message);
          setLoading(false);
          setStatus('error');
        }
      }

      const approvedCount = Object.values(decisions).filter(d => d === 'approved').length;
      const canCommit = status === 'pending' && approvedCount > 0;
      const canAnalyze = (status === 'idle' || status === 'error') && inputCode.trim().length > 0;
      const isAnalyzeDisabled = !canAnalyze || status === 'loading';

      const findingsTabLabel = findings.length > 0 ? `Findings (${findings.length})` : 'Findings';

      useEffect(() => {
        function handleKeyDown(e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            if (canAnalyze) handleAnalyze();
          }
        }
        window.addEventListener('keydown', handleKeyDown);
        return () => window.removeEventListener('keydown', handleKeyDown);
      }, [canAnalyze, inputCode]);

      return (
        <div className="app-shell">
          {/* ── HEADER BAR ── */}
          <div className="header-bar bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200 text-black dark:text-[#e6edf3]">
            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              <button 
                onClick={() => setSidebarOpen(prev => !prev)}
                className="text-gray-800 dark:text-[#e6edf3]"
                style={{ background: 'transparent', border: 'none', cursor: 'pointer', fontSize: 18, padding: '0 4px', marginRight: '4px' }}
              >
                ☰
              </button>
              <div style={{
                width: 28, height: 28, borderRadius: 7,
                background: 'linear-gradient(135deg, #6366f1, #8b5cf6)',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
                boxShadow: '0 0 12px rgba(99, 102, 241, 0.3)',
              }}>
                <ShieldIcon size={16} />
              </div>
              <span style={{ fontSize: 14, fontWeight: 700, letterSpacing: '-0.01em' }}>
                Sentinel-Graph
              </span>
            </div>
            <div style={{ flex: 1 }} />
            
            <button 
              onClick={toggleTheme} 
              className="mr-3 flex items-center justify-center p-1.5 rounded-md bg-gray-200 dark:bg-[#21262d] text-gray-800 dark:text-[#e6edf3] hover:bg-gray-300 dark:hover:bg-[#30363d] transition-colors duration-200"
              title="Toggle Light/Dark Theme"
            >
              {theme === 'dark' ? '☀️' : '🌙'}
            </button>

            <StatusBadge status={status} />
            {error && (
              <div style={{
                display: 'flex', alignItems: 'center', gap: 6,
                background: 'rgba(248,81,73,0.1)', padding: '3px 10px',
                borderRadius: 6, fontSize: 11, color: '#f85149', fontWeight: 500,
                maxWidth: 300, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap'
              }}>
                ⚠ {error}
              </div>
            )}
          </div>

          {/* ── MAIN AREA ── */}
          <div className="main-area bg-white dark:bg-[#0d1117] text-black dark:text-[#e6edf3] transition-colors duration-200" style={{ flex: 1, display: 'flex' }}>
            {PanelGroup ? (
              <>
                <div style={{ width: sidebarOpen ? '0px' : '60px', transition: 'width 0.2s ease', flexShrink: 0, overflow: 'hidden' }}>
                  {!sidebarOpen && (
                    <Sidebar 
                      sessions={sessions} 
                      activeSessionId={activeSessionId} 
                      onSelectSession={handleSelectSession} 
                      onCreateSession={handleCreateSession} 
                      isOpen={false}
                    />
                  )}
                </div>
                <PanelGroup direction="horizontal" autoSaveId="sentinel-layout-main" style={{ flex: 1 }}>
                  {/* LEFT: Sidebar Panel */}
                  {sidebarOpen && (
                    <>
                      <Panel defaultSize={20} minSize={10} id="sidebar-panel">
                        <Sidebar 
                          sessions={sessions} 
                          activeSessionId={activeSessionId} 
                          onSelectSession={handleSelectSession} 
                          onCreateSession={handleCreateSession} 
                          isOpen={true}
                        />
                      </Panel>
                      <ResizeHandle />
                    </>
                  )}

                  {/* CENTER: Code Editor Panel */}
                  <Panel defaultSize={40} minSize={20} id="editor-panel">
                    <div className="editor-pane">
                    <div className="pane-header bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                      <svg width={14} height={14} viewBox="0 0 24 24" fill="none" stroke="currentColor" className="text-gray-500 dark:text-[#8b949e]" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
                        <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                      </svg>
                      <span className="text-gray-500 dark:text-[#8b949e]">Editor</span>
                      <div style={{ flex: 1 }} />
                      <span className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: 10, fontFamily: "'JetBrains Mono', monospace" }}>
                        {inputCode.split('\n').length} lines
                      </span>
                    </div>
                    <Editor
                      key={theme}
                      theme={theme === "dark" ? "vs-dark" : "light"}
                      value={inputCode}
                      onChange={setInputCode}
                      disabled={status === 'loading' || status === 'approving'}
                    />
                  </div>
                </Panel>

                 <ResizeHandle />

                {/* RIGHT: Tools Panel Split */}
                <Panel defaultSize={40} minSize={25} id="right-panel">
                  <PanelGroup direction="vertical" autoSaveId="sentinel-layout-right">
                    {/* Tools Panel TOP: Logs/Findings */}
                    <Panel defaultSize={50} minSize={20} id="findings-panel">
                      <div className="right-pane bg-gray-50 dark:bg-[#0d1117]">
                        <div className="tab-strip bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                          <button className={`tab-btn ${activeTab === 'problem' ? 'active' : ''}`} onClick={() => setActiveTab('problem')}>Problem Input</button>
                          <button className={`tab-btn ${activeTab === 'logs' ? 'active' : ''}`} onClick={() => setActiveTab('logs')}><TerminalIcon size={13} />Logs</button>
                          <button className={`tab-btn ${activeTab === 'findings' ? 'active' : ''}`} onClick={() => setActiveTab('findings')}><ListIcon size={13} />{findingsTabLabel}</button>
                        </div>
                        <div className="tab-content" style={{ overflowY: 'auto', flex: 1 }}>
                          {activeTab === 'problem' && (
                            <div style={{ padding: '16px', display: 'flex', flexDirection: 'column', height: '100%', gap: '12px' }}>
                              <textarea
                                value={problemDescription}
                                onChange={(e) => setProblemDescription(e.target.value)}
                                placeholder="Paste your Codeforces / CodeChef problem here..."
                                disabled={analyzingProblem}
                                className="bg-white dark:bg-[#0d1117] text-gray-900 dark:text-[#e6edf3] border border-gray-200 dark:border-[#21262d]"
                                style={{ flex: 1, resize: 'none', padding: '12px', borderRadius: '6px', fontFamily: 'inherit', fontSize: '13px' }}
                              />
                              
                              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                                <h3 className="text-gray-900 dark:text-[#e6edf3]" style={{ margin: 0, fontSize: '14px', fontWeight: 'bold' }}>Problem Analysis</h3>
                                <button 
                                  onClick={handleAnalyzeProblem}
                                  disabled={analyzingProblem || !problemDescription.trim()}
                                  className="bg-blue-600 text-white hover:bg-blue-700 transition-colors duration-200"
                                  style={{ padding: '6px 12px', borderRadius: '4px', fontSize: '12px', fontWeight: 'bold', cursor: (analyzingProblem || !problemDescription.trim()) ? 'not-allowed' : 'pointer', opacity: (analyzingProblem || !problemDescription.trim()) ? 0.6 : 1 }}
                                >
                                  {analyzingProblem ? 'Analyzing...' : '🔍 Analyze Problem'}
                                </button>
                              </div>
                              
                              {problemAnalysis ? (
                                <div className="bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-3 rounded" style={{ fontSize: '12px', overflowY: 'auto' }}>
                                  {/* Agent Progress Tracker */}
                                  <ProblemAgentTracker running={analyzingProblem} completed={problemAnalysisDone} />
                                  <div style={{ marginBottom: '8px' }}>
                                    <strong className="text-gray-900 dark:text-[#e6edf3]">Problem Type:</strong> 
                                    <span className="ml-2 px-2 py-0.5 bg-gray-200 dark:bg-[#21262d] text-gray-800 dark:text-[#8b949e] rounded text-[10px] uppercase font-bold">{problemAnalysis.problem_type}</span>
                                  </div>
                                  <div style={{ marginBottom: '8px' }}>
                                    <strong className="text-gray-900 dark:text-[#e6edf3]">Input Format:</strong>
                                    <p className="text-gray-700 dark:text-[#8b949e] m-0 mt-1 whitespace-pre-wrap">{problemAnalysis.input_format}</p>
                                  </div>
                                  <div style={{ marginBottom: '8px' }}>
                                    <strong className="text-gray-900 dark:text-[#e6edf3]">Output Format:</strong>
                                    <p className="text-gray-700 dark:text-[#8b949e] m-0 mt-1 whitespace-pre-wrap">{problemAnalysis.output_format}</p>
                                  </div>
                                  <div>
                                    <strong className="text-gray-900 dark:text-[#e6edf3]">Constraints:</strong>
                                    <ul className="text-gray-700 dark:text-[#8b949e] m-0 mt-1 pl-4" style={{ listStyleType: 'disc' }}>
                                      {Object.entries(problemAnalysis.constraints || {}).map(([key, val]) => (
                                        <li key={key}><code style={{ background: 'rgba(0,0,0,0.1)', padding: '1px 3px', borderRadius: '3px'}}>{key}</code>: {val}</li>
                                      ))}
                                    </ul>
                                  </div>
                                  
                                  {constraintInsights && (
                                    <div style={{ marginTop: '12px', borderTop: '1px solid rgba(128,128,128,0.2)', paddingTop: '12px' }}>
                                      <strong className="text-gray-900 dark:text-[#e6edf3]">1. Constraints Insight</strong>
                                      <div className="mt-2 text-gray-700 dark:text-[#8b949e]">
                                        Scale: {constraintInsights.scale} | Cases: {constraintInsights.test_case_count}
                                        {constraintInsights.tight_constraints?.length > 0 && <div><strong className="text-gray-600">Tight:</strong> {constraintInsights.tight_constraints.join(", ")}</div>}
                                      </div>
                                    </div>
                                  )}

                                  {expectedTC && (
                                    <div style={{ marginTop: '12px', borderTop: '1px solid rgba(128,128,128,0.2)', paddingTop: '12px' }}>
                                      <strong className="text-gray-900 dark:text-[#e6edf3]">2. Complexity Estimate</strong>
                                      <div className="mt-2 text-gray-700 dark:text-[#8b949e]">
                                        <strong>TC:</strong> {expectedTC} | <strong>SC:</strong> {expectedSC}
                                        <p className="mt-1">{complexityReasoning}</p>
                                      </div>
                                    </div>
                                  )}

                                  {detectedPattern && (
                                    <div style={{ marginTop: '12px', borderTop: '1px solid rgba(128,128,128,0.2)', paddingTop: '12px' }}>
                                      <strong className="text-gray-900 dark:text-[#e6edf3]">3. Detected Pattern</strong>
                                      <div className="mt-2 text-gray-700 dark:text-[#8b949e] flex items-center gap-2">
                                        <span className="px-2 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 rounded font-bold uppercase">{detectedPattern}</span>
                                        <span>(Confidence: {Math.round(patternConfidence * 100)}%)</span>
                                      </div>
                                    </div>
                                  )}

                                  {strategyPlan && (
                                    <div style={{ marginTop: '12px', borderTop: '1px solid rgba(128,128,128,0.2)', paddingTop: '12px' }}>
                                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                                        <strong className="text-gray-900 dark:text-[#e6edf3]">4. Strategy Plan</strong>
                                        {strategyPlan.confidence !== undefined && (
                                          <span style={{ fontSize: '10px' }} className={`px-2 py-0.5 rounded font-bold uppercase ${strategyPlan.confidence >= 0.8 ? 'bg-green-100 text-green-800' : strategyPlan.confidence >= 0.5 ? 'bg-yellow-100 text-yellow-800' : 'bg-red-100 text-red-800'}`}>
                                            Conf: {Math.round(strategyPlan.confidence * 100)}%
                                          </span>
                                        )}
                                      </div>
                                      <div className="mt-2 text-gray-700 dark:text-[#8b949e]">
                                        <p className="font-medium text-gray-900 dark:text-[#e6edf3]">{strategyPlan.strategy}</p>
                                        <ul className="pl-4 mt-2 mb-2" style={{ listStyleType: 'decimal' }}>
                                          {strategyPlan.approach_steps?.map((step, i) => <li key={i}>{step}</li>)}
                                        </ul>
                                        {strategyPlan.alternative_strategies?.length > 0 && (
                                          <div className="mt-2 text-xs">
                                            <strong>Alternatives:</strong> {strategyPlan.alternative_strategies.join(" | ")}
                                          </div>
                                        )}
                                        {strategyPlan.edge_case_plan?.length > 0 && (
                                          <div className="mt-1 text-xs">
                                            <strong>Edge Cases to Handle:</strong> {strategyPlan.edge_case_plan.join(" | ")}
                                          </div>
                                        )}
                                        <p className="italic text-[11px] opacity-80 mt-2">{strategyPlan.justification}</p>
                                      </div>
                                    </div>
                                  )}

                                  {testCaseValidation && (
                                    <div style={{ marginTop: '12px', borderTop: '1px solid rgba(128,128,128,0.2)', paddingTop: '12px' }}>
                                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                                        <strong className="text-gray-900 dark:text-[#e6edf3]">5. Simulation & Validation</strong>
                                        <span style={{ fontSize: '10px' }} className={`px-2 py-0.5 rounded font-bold uppercase ${testCaseValidation.passes_sample_tests ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                                          {testCaseValidation.passes_sample_tests ? '✅ PASS' : '❌ FAIL'}
                                        </span>
                                      </div>
                                      <div className="mt-2 text-gray-700 dark:text-[#8b949e]">
                                        <div style={{ display: 'flex', gap: '8px', marginBottom: '8px' }}>
                                           <span className="px-2 py-0.5 bg-gray-200 dark:bg-[#30363d] text-gray-800 dark:text-[#e6edf3] rounded text-[10px] uppercase font-bold">
                                             Mode: {testCaseValidation.validation_mode}
                                           </span>
                                           <span className="px-2 py-0.5 bg-gray-200 dark:bg-[#30363d] text-gray-800 dark:text-[#e6edf3] rounded text-[10px] uppercase font-bold">
                                             Conf: {Math.round(testCaseValidation.confidence_score * 100)}%
                                           </span>
                                        </div>
                                        {testCaseValidation.validation_mode !== "skipped_non_deterministic" && (
                                           <div className="mt-2 grid grid-cols-2 gap-2 text-xs">
                                              <div className="p-2 bg-gray-100 dark:bg-[#0d1117] rounded border border-gray-200 dark:border-[#30363d]">
                                                <strong>Predicted:</strong> <br/><span className="whitespace-pre-wrap">{testCaseValidation.predicted_output || 'N/A'}</span>
                                              </div>
                                              <div className="p-2 bg-gray-100 dark:bg-[#0d1117] rounded border border-gray-200 dark:border-[#30363d]">
                                                <strong>Expected:</strong> <br/><span className="whitespace-pre-wrap">{testCaseValidation.expected_output || 'N/A'}</span>
                                              </div>
                                           </div>
                                        )}
                                        {testCaseValidation.failed_cases?.length > 0 && (
                                          <div className="mt-2 text-xs text-red-600 dark:text-red-400">
                                            <strong>Failures:</strong>
                                            <ul className="pl-4 list-disc">
                                              {testCaseValidation.failed_cases.map((c, i) => <li key={i}>{c}</li>)}
                                            </ul>
                                          </div>
                                        )}
                                        {testCaseValidation.edge_case_analysis?.length > 0 && (
                                          <div className="mt-2 text-xs">
                                            <strong>Edge Cases simulated:</strong>
                                            <ul className="pl-4 list-disc">
                                              {testCaseValidation.edge_case_analysis.map((e, i) => <li key={i}>{e}</li>)}
                                            </ul>
                                          </div>
                                        )}
                                      </div>
                                    </div>
                                  )}
                                  
                                  {analysisStatus === 'PENDING_DECISION' && (
                                    <div style={{ marginTop: '16px', padding: '16px', background: 'rgba(59, 130, 246, 0.1)', border: '1px solid rgba(59, 130, 246, 0.3)', borderRadius: '8px', textAlign: 'center' }}>
                                      <h3 className="text-blue-800 dark:text-blue-300 font-bold mb-3">Analysis Complete. How would you like to proceed?</h3>
                                      <div style={{ display: 'flex', gap: '8px', justifyContent: 'center' }}>
                                        <button onClick={() => handleDecision('hints')} className="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded text-xs font-bold transition-colors">💡 Get Hints</button>
                                        <button onClick={() => handleDecision('generate')} className="px-3 py-1.5 bg-purple-600 hover:bg-purple-700 text-white rounded text-xs font-bold transition-colors">⚡ Generate Code</button>
                                        <button onClick={() => handleDecision('manual')} className="px-3 py-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded text-xs font-bold transition-colors">✍️ Write My Own</button>
                                      </div>
                                    </div>
                                  )}
                                  {analysisStatus === 'LOADING_DECISION' && (
                                    <div style={{ marginTop: '16px', textAlign: 'center', color: '#8b949e', fontSize: '12px', fontStyle: 'italic' }}>
                                      Processing decision...
                                    </div>
                                  )}
                                  {analysisStatus === 'RESUMED' && (
                                    <div style={{ marginTop: '16px', textAlign: 'center', color: '#4ade80', fontSize: '12px', fontWeight: 'bold' }}>
                                      ✅ Graph resumed based on your choice.
                                    </div>
                                  )}

                                </div>
                              ) : analyzingProblem ? (
                                <div className="bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-3 rounded" style={{ fontSize: '12px', overflowY: 'auto' }}>
                                  <ProblemAgentTracker running={analyzingProblem} completed={false} />
                                </div>
                              ) : (
                                <div className="text-gray-500 dark:text-[#8b949e] flex items-center justify-center border border-dashed border-gray-300 dark:border-[#30363d] rounded p-4" style={{ flex: 1, fontSize: '12px', textAlign: 'center' }}>
                                  No analysis yet. Click "Analyze Problem" to process.
                                </div>
                              )}
                            </div>
                          )}
                          {activeTab === 'logs' ? (
                            <LogsPanel loading={status === 'loading'} completed={status === 'pending' || status === 'completed' || status === 'approving'} />
                          ) : (
                            <FindingsList findings={findings} decisions={decisions} onApprove={handleApproveItem} onReject={handleRejectItem} onApproveAll={handleApproveAll} onRejectAll={handleRejectAll} />
                          )}
                        </div>
                      </div>
                    </Panel>

                    <ResizeHandle vertical />

                    {/* Tools Panel BOTTOM: Diff Viewer */}
                    <Panel defaultSize={50} minSize={20} id="diff-panel">
                      <div className="right-pane bg-gray-50 dark:bg-[#0d1117] diff-section border-t border-gray-200 dark:border-[#21262d]">
                        <div className="pane-header bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                          <DiffIcon size={13} />
                          <span className="text-gray-500 dark:text-[#8b949e]">Diff Viewer</span>
                        </div>
                        <div className="tab-content" style={{ padding: 0 }}>
                          <DiffViewer diffData={diffData} />
                        </div>
                      </div>
                    </Panel>
                  </PanelGroup>
                </Panel>
              </PanelGroup>
              </>
            ) : (
              <div style={{ display: 'flex', width: '100%', height: '100%' }}>
                <div style={{ width: sidebarOpen ? '250px' : '60px', borderRight: '1px solid #21262d', transition: 'width 0.2s ease' }}>
                  <Sidebar 
                    sessions={sessions} 
                    activeSessionId={activeSessionId} 
                    onSelectSession={handleSelectSession} 
                    onCreateSession={handleCreateSession} 
                    isOpen={sidebarOpen}
                  />
                </div>
                <div className="editor-pane" style={{ flex: 1 }}>
                  <div className="pane-header bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                    <svg width={14} height={14} viewBox="0 0 24 24" fill="none" stroke="currentColor" className="text-gray-500 dark:text-[#8b949e]" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round">
                      <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                    </svg>
                    <span className="text-gray-500 dark:text-[#8b949e]">Editor</span>
                    <div style={{ flex: 1 }} />
                    <span className="text-gray-500 dark:text-[#8b949e]" style={{ fontSize: 10, fontFamily: "'JetBrains Mono', monospace" }}>
                      {inputCode.split('\n').length} lines
                    </span>
                  </div>
                  <Editor
                    key={theme}
                    theme={theme === "dark" ? "vs-dark" : "light"}
                    value={inputCode}
                    onChange={setInputCode}
                    disabled={status === 'loading' || status === 'approving'}
                  />
                </div>
                <div className="right-pane bg-gray-50 dark:bg-[#0d1117]" style={{ width: '40%' }}>
                  <div className="tab-strip bg-white dark:bg-[#161b22] border-b border-gray-200 dark:border-[#21262d] transition-colors duration-200">
                    <button className={`tab-btn ${activeTab === 'problem' ? 'active' : ''}`} onClick={() => setActiveTab('problem')}>Problem Input</button>
                    <button className={`tab-btn ${activeTab === 'logs' ? 'active' : ''}`} onClick={() => setActiveTab('logs')}><TerminalIcon size={13} />Logs</button>
                    <button className={`tab-btn ${activeTab === 'findings' ? 'active' : ''}`} onClick={() => setActiveTab('findings')}><ListIcon size={13} />{findingsTabLabel}</button>
                    <button className={`tab-btn ${activeTab === 'results' ? 'active' : ''}`} onClick={() => setActiveTab('results')}><DiffIcon size={13} />Results</button>
                  </div>
                  <div className="tab-content">
                    {activeTab === 'problem' && (
                      <div style={{ padding: '16px', display: 'flex', flexDirection: 'column', height: '100%', gap: '12px' }}>
                        <textarea
                          value={problemDescription}
                          onChange={(e) => setProblemDescription(e.target.value)}
                          placeholder="Paste your Codeforces / CodeChef problem here..."
                          disabled={analyzingProblem}
                          className="bg-white dark:bg-[#0d1117] text-gray-900 dark:text-[#e6edf3] border border-gray-200 dark:border-[#21262d]"
                          style={{ flex: 1, resize: 'none', padding: '12px', borderRadius: '6px', fontFamily: 'inherit', fontSize: '13px' }}
                        />

                        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                          <h3 className="text-gray-900 dark:text-[#e6edf3]" style={{ margin: 0, fontSize: '14px', fontWeight: 'bold' }}>Problem Analysis</h3>
                          <button 
                            onClick={handleAnalyzeProblem}
                            disabled={analyzingProblem || !problemDescription.trim()}
                            className="bg-blue-600 text-white hover:bg-blue-700 transition-colors duration-200"
                            style={{ padding: '6px 12px', borderRadius: '4px', fontSize: '12px', fontWeight: 'bold', cursor: (analyzingProblem || !problemDescription.trim()) ? 'not-allowed' : 'pointer', opacity: (analyzingProblem || !problemDescription.trim()) ? 0.6 : 1 }}
                          >
                            {analyzingProblem ? 'Analyzing...' : '🔍 Analyze Problem'}
                          </button>
                        </div>
                        
                        {problemAnalysis ? (
                          <div className="bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-3 rounded" style={{ fontSize: '12px', overflowY: 'auto', flex: 1 }}>
                            {/* Agent Progress Tracker */}
                            <ProblemAgentTracker running={analyzingProblem} completed={problemAnalysisDone} />
                            <div style={{ marginBottom: '8px' }}>
                              <strong className="text-gray-900 dark:text-[#e6edf3]">Problem Type:</strong> 
                              <span className="ml-2 px-2 py-0.5 bg-gray-200 dark:bg-[#21262d] text-gray-800 dark:text-[#8b949e] rounded text-[10px] uppercase font-bold">{problemAnalysis.problem_type}</span>
                            </div>
                            <div style={{ marginBottom: '8px' }}>
                              <strong className="text-gray-900 dark:text-[#e6edf3]">Input Format:</strong>
                              <p className="text-gray-700 dark:text-[#8b949e] m-0 mt-1 whitespace-pre-wrap">{problemAnalysis.input_format}</p>
                            </div>
                            <div style={{ marginBottom: '8px' }}>
                              <strong className="text-gray-900 dark:text-[#e6edf3]">Output Format:</strong>
                              <p className="text-gray-700 dark:text-[#8b949e] m-0 mt-1 whitespace-pre-wrap">{problemAnalysis.output_format}</p>
                            </div>
                            <div>
                              <strong className="text-gray-900 dark:text-[#e6edf3]">Constraints:</strong>
                              <ul className="text-gray-700 dark:text-[#8b949e] m-0 mt-1 pl-4" style={{ listStyleType: 'disc' }}>
                                {Object.entries(problemAnalysis.constraints || {}).map(([key, val]) => (
                                  <li key={key}><code style={{ background: 'rgba(0,0,0,0.1)', padding: '1px 3px', borderRadius: '3px'}}>{key}</code>: {val}</li>
                                ))}
                              </ul>
                            </div>
                          </div>
                        ) : analyzingProblem ? (
                          <div className="bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-3 rounded" style={{ fontSize: '12px', overflowY: 'auto', flex: 1 }}>
                            <ProblemAgentTracker running={analyzingProblem} completed={false} />
                          </div>
                        ) : (
                          <div className="text-gray-500 dark:text-[#8b949e] flex items-center justify-center border border-dashed border-gray-300 dark:border-[#30363d] rounded p-4" style={{ flex: 1, fontSize: '12px', textAlign: 'center' }}>
                            No analysis yet. Click "Analyze Problem" to process.
                          </div>
                        )}
                      </div>
                    )}
                    {activeTab === 'logs' && <LogsPanel loading={status === 'loading'} completed={status === 'pending' || status === 'completed' || status === 'approving'} />}
                    {activeTab === 'findings' && <FindingsList findings={findings} decisions={decisions} onApprove={handleApproveItem} onReject={handleRejectItem} onApproveAll={handleApproveAll} onRejectAll={handleRejectAll} />}
                    {activeTab === 'results' && <DiffViewer diffData={diffData} />}
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* ── ACTION BAR ── */}
          <div className="action-bar">
            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              {(status === 'pending' || status === 'completed') && (
                <button className="btn-reset text-gray-900 dark:text-white" onClick={handleReset}>
                  <RefreshIcon size={12} />
                  New Review
                </button>
              )}
              {status === 'completed' && activeSessionId && (
                <button 
                  className="btn-reset text-gray-900 dark:text-white"
                  onClick={handleImproveCode}
                  style={{ background: 'rgba(56, 139, 253, 0.15)', borderColor: '#388bfd' }}
                >
                  <ZapIcon size={12} />
                  Improve My Code
                </button>
              )}
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              {status === 'pending' && (
                <span style={{ fontSize: 12, color: '#8b949e' }}>
                  <span style={{ color: '#3fb950', fontWeight: 600 }}>{approvedCount}</span> approved
                </span>
              )}
              <button
                className="btn-primary btn-analyze"
                onClick={handleAnalyze}
                disabled={isAnalyzeDisabled}
                style={{ display: status === 'pending' || status === 'approving' || status === 'completed' ? 'none' : 'inline-flex' }}
                title="Ctrl+Enter"
              >
                {status === 'loading' ? (
                  <><SpinnerIcon size={14} /> Analyzing...</>
                ) : (
                  <><ZapIcon size={14} /> Analyze Code</>
                )}
              </button>
              <button
                className="btn-primary btn-commit"
                onClick={handleCommit}
                disabled={!canCommit}
                style={{ display: status === 'pending' || status === 'approving' ? 'inline-flex' : 'none' }}
              >
                {status === 'approving' ? (
                  <><SpinnerIcon size={14} /> Committing...</>
                ) : (
                  <><CheckIcon size={14} /> Commit Changes</>
                )}
              </button>
            </div>
          </div>
        </div>
      );
    }

    /* ═══════════════════════════════════════════════
       MOUNT
       ═══════════════════════════════════════════════ */

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(
      <ErrorBoundary>
        <App />
      </ErrorBoundary>
    );
  </script>
</body>
</html>
